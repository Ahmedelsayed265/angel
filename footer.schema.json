{
  "icon": "fa fa-square",
  "name": {
    "ar": "اسفل الصفحة",
    "en": "footer"
  },
  "groups": [
    {
      "id": "layout_footer",
      "icon": "fa fa-window-minimize",
      "name": {
        "ar": "إعدادات عامة للتذييل",
        "en": "Footer layout"
      },
      "settings": [
        {
          "id": "bg_color",
          "type": "color",
          "label": {
            "ar": "لون خلفية أسفل الصفحة",
            "en": "Footer background color"
          }
        },
        {
          "id": "logo_scale",
          "type": "text",
          "label": {
            "ar": "حجم شعار المتجر في أسفل الصفحة",
            "en": "Footer logo size"
          },
          "info": {
            "ar": "قيمة من 0 إلى 10 (مثال: 2.5). الافتراضي 2.5.",
            "en": "Value from 0 to 10 (e.g. 2.5). Default is 2.5."
          },
          "default": "2.5"
        },
        {
          "id": "show_payment_icons",
          "type": "checkbox",
          "label": {
            "ar": "عرض صور وسائل الدفع الافتراضية",
            "en": "Show default payment method icons"
          },
          "default": false
        },
        {
          "id": "extra_logos",
          "type": "list",
          "label": {
            "ar": "شعارات إضافية أسفل الصفحة",
            "en": "Additional footer logos"
          },
          "settings": [
            {
              "id": "image",
              "type": "image",
              "label": {
                "ar": "ارفع صورة الشعار",
                "en": "Logo image"
              }
            },
            {
              "id": "url",
              "type": "url",
              "label": {
                "ar": "رابط الشعار",
                "en": "Logo link"
              }
            }
          ]
        },
        {
          "id": "hide_back_to_top",
          "type": "checkbox",
          "label": {
            "ar": "إخفاء زر الصعود لأعلى",
            "en": "Hide back-to-top button"
          },
          "default": false
        },
        {
          "id": "compact",
          "type": "checkbox",
          "label": {
            "ar": "تصغير أسفل الصفحة",
            "en": "Compact footer"
          },
          "info": {
            "ar": "يُخفى قسم النشرة البريدية عند تفعيل هذا الخيار.",
            "en": "Hides the newsletter block when enabled."
          },
          "default": false
        },
        {
          "id": "newsletter_enabled",
          "type": "checkbox",
          "label": {
            "ar": "تفعيل النشرة البريدية أسفل المتجر",
            "en": "Enable store newsletter"
          },
          "default": true
        },
        {
          "id": "newsletter_form_url",
          "type": "url",
          "label": {
            "ar": "رابط النشرة البريدية",
            "en": "Newsletter form URL"
          },
          "info": {
            "ar": "رابط إرسال النموذج (مثل Google Apps Script). إذا كان موجودًا سيتم استخدامه بدل رابط مجموعة «النشرة البريدية».",
            "en": "Form POST URL (e.g. Google Apps Script). If set, it overrides Newsletter → Form URL."
          }
        }
      ]
    },
    {
      "id": "newsletter",
      "icon": "fa fa-envelope",
      "name": {
        "ar": "النشرة البريدية",
        "en": "Newsletter"
      },
      "settings": [
        {
          "id": "hide",
          "type": "checkbox",
          "label": {
            "ar": "إخفاء قسم النشرة وشريط التواصل العلوي",
            "en": "Hide newsletter and top social row"
          }
        },
        {
          "id": "title",
          "type": "text",
          "label": {
            "ar": "عنوان النشرة (بجانب حقل الاشتراك)",
            "en": "Newsletter title (next to signup)"
          }
        },
        {
          "id": "description",
          "type": "textarea",
          "label": {
            "ar": "وصف النشرة (بجانب حقل الاشتراك)",
            "en": "Newsletter description (next to signup)"
          }
        },
        {
          "id": "placeholder",
          "type": "text",
          "label": {
            "ar": "نص توضيحي لحقل البريد",
            "en": "Email field placeholder"
          }
        },
        {
          "id": "button_text",
          "type": "text",
          "label": {
            "ar": "نص زر الاشتراك",
            "en": "Subscribe button label"
          }
        },
        {
          "id": "youtube_url",
          "type": "url",
          "label": {
            "ar": "رابط يوتيوب (شريط الأيقونات العلوي)",
            "en": "YouTube URL (top icon row)"
          }
        },
        {
          "id": "form_action_url",
          "type": "url",
          "label": {
            "ar": "رابط إرسال النشرة البريدية",
            "en": "Newsletter form POST URL"
          },
          "info": {
            "ar": "يمكن أيضاً ضبطه من إعدادات التخطيط → أسفل الصفحة.",
            "en": "Can also be set under Layout → Footer."
          }
        }
      ]
    },
    {
      "id": "footer_brand",
      "icon": "fa fa-image",
      "name": {
        "ar": "شعار التذييل",
        "en": "Footer brand"
      },
      "settings": [
        {
          "id": "logo",
          "type": "image",
          "label": {
            "ar": "شعار مخصص (اختياري)",
            "en": "Custom footer logo (optional)"
          }
        },
        {
          "id": "subtitle",
          "type": "text",
          "label": {
            "ar": "نص تحت الشعار",
            "en": "Text under logo"
          },
          "default": "متجر تجريبي - Demo Store"
        }
      ]
    },
    {
      "id": "customer_service",
      "icon": "fa fa-headphones",
      "name": {
        "ar": "خدمة العملاء",
        "en": "Customer service"
      },
      "settings": [
        {
          "id": "hide",
          "type": "checkbox",
          "label": {
            "ar": "إخفاء قسم خدمة العملاء",
            "en": "Hide customer service column"
          }
        },
        {
          "id": "title",
          "type": "text",
          "label": {
            "ar": "عنوان القسم",
            "en": "Section title"
          }
        },
        {
          "id": "telegram_url",
          "type": "url",
          "label": {
            "ar": "رابط تيليجرام",
            "en": "Telegram link"
          }
        },
        {
          "id": "email",
          "type": "text",
          "label": {
            "ar": "البريد الإلكتروني",
            "en": "Email address"
          }
        },
        {
          "id": "phone",
          "type": "text",
          "label": {
            "ar": "رقم الهاتف",
            "en": "Phone number"
          }
        },
        {
          "id": "mobile_url",
          "type": "url",
          "label": {
            "ar": "رابط التطبيق أو الجوال",
            "en": "Mobile / app link"
          }
        }
      ]
    },
    {
      "id": "app_section",
      "icon": "fa fa-mobile",
      "name": {
        "ar": "قسم التطبيق",
        "en": "Mobile app"
      },
      "settings": [
        {
          "id": "hide",
          "type": "checkbox",
          "label": {
            "ar": "إخفاء قسم التطبيق",
            "en": "Hide app download section"
          }
        },
        {
          "id": "title",
          "type": "text",
          "label": {
            "ar": "عنوان قسم التطبيق",
            "en": "App section title"
          }
        },
        {
          "id": "google_play_url",
          "type": "url",
          "label": {
            "ar": "رابط Google Play",
            "en": "Google Play link"
          }
        },
        {
          "id": "google_play_image",
          "type": "image",
          "label": {
            "ar": "صورة زر Google Play",
            "en": "Google Play button image"
          }
        },
        {
          "id": "app_store_url",
          "type": "url",
          "label": {
            "ar": "رابط App Store",
            "en": "App Store link"
          }
        },
        {
          "id": "app_store_image",
          "type": "image",
          "label": {
            "ar": "صورة زر App Store",
            "en": "App Store button image"
          }
        }
      ]
    },
    {
