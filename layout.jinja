<script>
(function () {
  var tabs = document.querySelectorAll('.angel-header-home-tabs [data-hero-tab]');
  if (!tabs || !tabs.length) return;

  function setActiveTab(index) {
    if (!index) return;
    var activeId = String(index);

    tabs.forEach(function (tab) {
      var tabId = String(tab.getAttribute('data-hero-tab') || '');
      var isActive = tabId === activeId;
      tab.classList.toggle('is-active', isActive);
      tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    document.querySelectorAll('[data-home-tab]').forEach(function (el) {
      var target = String(el.getAttribute('data-home-tab') || '').trim();
      if (!target) return;
      var show = target === activeId;
      el.hidden = !show;
      el.classList.toggle('angel-home-tab-hidden', !show);
      if (show) {
        el.removeAttribute('hidden');
        el.style.removeProperty('display');
      }
    });

    try {
      window.dispatchEvent(new CustomEvent('angel:homeTabChange', { detail: { tab: activeId } }));
    } catch (e) {}
  }

  var initial = null;
  tabs.forEach(function (tab) {
    if (!initial && tab.classList.contains('is-active')) {
      initial = tab.getAttribute('data-hero-tab');
    }
    tab.addEventListener('click', function () {
      setActiveTab(tab.getAttribute('data-hero-tab'));
    });
  });
  if (!initial) initial = tabs[0].getAttribute('data-hero-tab');
  setActiveTab(initial);
})();
</script>

