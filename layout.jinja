{% set lp_enabled = settings.loading_page_enabled | default(false) %}
{% set lp_all = settings.loading_page_show_on_all_pages | default(false) %}
{% set lp_should_show = lp_enabled and (lp_all or session.template == 'home') %}
{% if lp_should_show %}
  {% set lp_bg = settings.loading_page_bg_color | default('#ffffff') %}
  {% set lp_img = (settings.loading_page_image_url | default('', true)) | trim %}
  {% set lp_logo_size = (settings.loading_page_logo_size | default('180', true)) | trim %}
  {% set lp_duration_raw = (settings.loading_page_duration_seconds | default('2', true)) | trim %}
  {% set lp_show_skip = settings.loading_page_show_skip | default(true) %}
  {% set lp_blur = settings.loading_page_blur_background | default(true) %}
  {% set lp_show_spinner = settings.loading_page_show_spinner | default(false) %}
  <div
    id="angel-loading-overlay"
    class="angel-loading-overlay{% if lp_blur %} angel-loading-overlay--blur{% endif %}"
    style="--angel-loading-bg: {{ lp_bg }}; --angel-loading-size: {{ lp_logo_size | e }}px;"
    aria-live="polite"
    aria-busy="true"
  >
    <div class="angel-loading-overlay__inner">
      {% if lp_img %}
        <img class="angel-loading-overlay__logo" src="{{ lp_img }}" alt="{{ store.name }}" loading="eager" decoding="async" />
      {% else %}
        <img class="angel-loading-overlay__logo" src="{{ image_url(store.logo, h=240, q=95) }}" alt="{{ store.name }}" loading="eager" decoding="async" />
      {% endif %}
      {% if lp_show_spinner %}
        <div class="angel-loading-overlay__spinner" aria-hidden="true"></div>
      {% endif %}
      {% if lp_show_skip %}
        <button type="button" class="angel-loading-overlay__skip" data-angel-loading-skip>{{ _("Skip") }}</button>
      {% endif %}
    </div>
  </div>
  <script>
  (function () {
    try {
      var overlay = document.getElementById('angel-loading-overlay');
      if (!overlay) return;

      function hide() {
        overlay.classList.add('is-hidden');
        window.setTimeout(function () {
          overlay.remove();
        }, 250);
      }

      var btn = overlay.querySelector('[data-angel-loading-skip]');
      if (btn) btn.addEventListener('click', hide);

      var seconds = Number({{ lp_duration_raw | default('2', true) | tojson }});
      if (Number.isNaN(seconds) || seconds < 0) seconds = 2;

      window.setTimeout(hide, Math.round(seconds * 1000));
    } catch (e) {}
  })();
  </script>
{% endif %}

