{% if product %}
{% set card_product = product %}
{% set selected_product = card_product.selected_product | default(card_product) %}
{% set has_preorder = card_product.effective_preorder_campaign is not none %}
{% set can_preorder = card_product.can_be_preordered %}
{% set is_in_stock_or_preorderable = card_product.is_infinite or card_product.quantity > 0 or can_preorder %}
{% set is_out_of_stock = (card_product.is_infinite == false and card_product.quantity <= 0) and not can_preorder %}
{% set stock_qty = selected_product.quantity | default(card_product.quantity, true) %}
{% set show_low_stock = (
    not card_product.is_infinite
    and stock_qty is not none
    and stock_qty > 0
    and stock_qty < 5
    and (selected_product.in_stock | default(card_product.in_stock, true))
) %}
{% set image_src = '' %}
{% if card_product.main_image and card_product.main_image.image %}
    {% set image_src = card_product.main_image.image.medium | default(card_product.main_image.image.full_size, true) %}
{% elif card_product.images and card_product.images | length > 0 %}
    {% set image_src = card_product.images[0].image.medium | default(card_product.images[0].image.full_size, true) %}
{% endif %}

<article class="angel-grouped-card{% if is_out_of_stock %} angel-grouped-card--out-of-stock{% endif %}">
    {% if show_low_stock %}
        <span class="angel-grouped-card__low-stock">{{ _("Almost out of stock") }}</span>
    {% endif %}
    <div class="angel-grouped-card__media">
        <a href="/products/{{ card_product.slug }}" class="angel-grouped-card__media-link" aria-label="{{ card_product.name | striptags }}">
            <img
                class="angel-grouped-card__img"
                src="{{ image_src if image_src else ('product-img.svg' | asset_url) }}"
                alt="{{ card_product.name | striptags }}"
                loading="lazy"
            />
        </a>
        <span class="angel-grouped-card__glass" aria-hidden="true"></span>
        {% if card_product.discount_percentage and card_product.discount_percentage > 0 %}
            <span class="angel-grouped-card__discount">{{ card_product.discount_percentage }}%</span>
        {% endif %}
        {% if store.settings.products.reviews_enabled and card_product.rating and card_product.rating.average %}
            <span class="angel-grouped-card__rating" aria-hidden="true">
                <span class="angel-grouped-card__rating-star">★</span>
                <span class="angel-grouped-card__rating-value">{{ card_product.rating.average }}</span>
            </span>
        {% endif %}
        <div class="angel-grouped-card__actions">
            {% if store.settings.products.wishlist_enabled == true %}
                <span class="add-to-wishlist angel-grouped-card__wishlist" data-wishlist-id="{{ card_product.id }}">
                    <span zid-visible-customer="true">
                        <button
                            type="button"
                            zid-visible-wishlist="{{ card_product.id }}"
                            class="angel-grouped-card__action-btn angel-grouped-card__action-btn--wishlist filled"
                            aria-label="{{ _('Wishlist') }}"
                            onclick="event.preventDefault(); event.stopPropagation(); addToWishlist(this, '{{ card_product.id }}')"
                        ><i class="sicon-heart"></i></button>
                        <button
                            type="button"
                            zid-hidden-wishlist="{{ card_product.id }}"
                            class="angel-grouped-card__action-btn angel-grouped-card__action-btn--wishlist"
                            aria-label="{{ _('Wishlist') }}"
                            onclick="event.preventDefault(); event.stopPropagation(); addToWishlist(this, '{{ card_product.id }}')"
                        ><i class="sicon-heart"></i></button>
                    </span>
                    <a
                        zid-visible-guest="true"
                        class="angel-grouped-card__action-btn angel-grouped-card__action-btn--wishlist"
                        href="/auth/login?redirect_to={{ session.url.path }}"
                        aria-label="{{ _('Wishlist') }}"
                        onclick="event.preventDefault(); event.stopPropagation(); handleLoginAction('', false); return false;"
                    ><i class="sicon-heart"></i></a>
                    <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="" />
                </span>
            {% endif %}
            {% set qv_brand_cat = card_product.categories[0] if card_product.categories and card_product.categories | length > 0 else none %}
            {% set qv_brand_img = '' %}
            {% set qv_brand_url = '' %}
            {% if qv_brand_cat %}
                {% set qv_brand_url = (qv_brand_cat.url | default('', true)) | trim or url_for('category_details', category_id=qv_brand_cat.id, slug=qv_brand_cat.slug or qv_brand_cat.id) %}
                {% if qv_brand_cat.cover_image %}
                    {% set qv_brand_img = image_url(qv_brand_cat.cover_image, w=160, q=90, f='auto') %}
                {% elif qv_brand_cat.image %}
                    {% set qv_brand_img = image_url(qv_brand_cat.image, w=160, q=90, f='auto') %}
                {% endif %}
            {% endif %}
            <button
                type="button"
                class="angel-grouped-card__action-btn angel-grouped-card__action-btn--view"
                data-grouped-quick-view
                data-product-id="{{ card_product.id }}"
                data-product-slug="{{ card_product.slug }}"
                {% if qv_brand_img %}data-brand-image="{{ qv_brand_img | e }}"{% endif %}
                {% if qv_brand_url %}data-brand-url="{{ qv_brand_url | e }}"{% endif %}
                aria-label="{{ _('View') }}"
            ><i class="sicon-eye"></i></button>
        </div>
    </div>

    <div class="angel-grouped-card__body">
        {% if card_product.categories and card_product.categories | length > 0 %}
            <div class="angel-grouped-card__brands">
                {% for cat in card_product.categories[:2] %}
                    <span class="angel-grouped-card__brand">{{ cat.name }}</span>
                {% endfor %}
            </div>
        {% endif %}

        <h3 class="angel-grouped-card__title">
            <a href="/products/{{ card_product.slug }}">{{ card_product.name | safe }}</a>
        </h3>

        <div class="angel-grouped-card__prices">
            {% if card_product.formatted_sale_price is not none %}
                <span class="angel-grouped-card__price">{{ card_product.formatted_sale_price }}</span>
                <del class="angel-grouped-card__price-old">{{ card_product.formatted_price }}</del>
            {% else %}
                <span class="angel-grouped-card__price">{{ card_product.formatted_price }}</span>
            {% endif %}
        </div>
    </div>

    <div class="angel-grouped-card__footer">
        {% if is_out_of_stock %}
            <a href="/products/{{ card_product.slug }}" class="angel-grouped-card__btn angel-grouped-card__btn--muted">
                {{ _("Notify me when available") }}
            </a>
        {% elif card_product.has_options or card_product.has_fields or card_product.product_class == 'dynamic_bundle' %}
            <a href="/products/{{ card_product.slug }}" class="angel-grouped-card__btn">
                <span class="angel-grouped-card__btn-icon" aria-hidden="true">+</span>
                <span>{{ _("add to cart") }}</span>
            </a>
        {% else %}
            <button
                type="button"
                class="angel-grouped-card__btn product-card-add-to-cart"
                onclick="event.preventDefault(); event.stopPropagation(); productCartAddToCart(this,'{{ card_product.id }}')"
            >
                <img class="angel-grouped-card__btn-progress add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="" />
                <span class="angel-grouped-card__btn-content">
                    <span class="angel-grouped-card__btn-icon" aria-hidden="true">+</span>
                    <span>{{ _("Preorder now") if has_preorder else _("add to cart") }}</span>
                </span>
            </button>
        {% endif %}
    </div>
    <script type="application/json" class="angel-grouped-card__data">{{ card_product | tojson }}</script>
</article>
{% endif %}
