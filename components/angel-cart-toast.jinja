{# Add-to-cart success / error toast — top-end corner #}
<div class="angel-cart-toast-host" id="angel-cart-toast-host" aria-live="polite" aria-atomic="true" hidden>
    <div class="angel-cart-toast angel-cart-toast--success" id="angel-cart-toast-success" role="status" hidden>
        <div class="angel-cart-toast__progress" aria-hidden="true"></div>
        <button type="button" class="angel-cart-toast__close" data-angel-cart-toast-close aria-label="{{ _('Close') }}">
            <span aria-hidden="true">&times;</span>
        </button>

        <h2 class="angel-cart-toast__title">{{ _("Added to shopping cart") }}</h2>

        <div class="angel-cart-toast__product">
            <div class="angel-cart-toast__product-media">
                <img class="angel-cart-toast__product-img" src="" alt="" width="72" height="72" loading="lazy" decoding="async" hidden />
            </div>
            <div class="angel-cart-toast__product-info">
                <p class="angel-cart-toast__product-name"></p>
                <p class="angel-cart-toast__product-price"></p>
            </div>
        </div>

        <div class="angel-cart-toast__summary">
            <div class="angel-cart-toast__thumbs" data-angel-cart-toast-thumbs></div>
            <div class="angel-cart-toast__summary-text">
                <p class="angel-cart-toast__summary-line" data-angel-cart-toast-summary></p>
                <a class="angel-cart-toast__view-cart" href="{{ url_for('cart_page') }}" data-angel-cart-toast-cart-link>
                    {{ _("View cart") }}
                    <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M1 1L5 5L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </div>
        </div>

        <div class="angel-cart-toast__actions">
            <button type="button" class="angel-cart-toast__btn angel-cart-toast__btn--ghost" data-angel-cart-toast-continue>
                {{ _("Continue shopping") }}
            </button>
            <a class="angel-cart-toast__btn angel-cart-toast__btn--primary" href="/checkout" data-angel-cart-toast-checkout>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M3 7.5H21L19.5 19.5H6L4.5 4.5H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="9" cy="21" r="1.25" fill="currentColor"/>
                    <circle cx="18" cy="21" r="1.25" fill="currentColor"/>
                </svg>
                <span>{{ _("Complete order") }}</span>
            </a>
        </div>
    </div>

    <div class="angel-cart-toast angel-cart-toast--error" id="angel-cart-toast-error" role="alert" hidden>
        <div class="angel-cart-toast__progress angel-cart-toast__progress--error" aria-hidden="true"></div>
        <button type="button" class="angel-cart-toast__close" data-angel-cart-toast-close aria-label="{{ _('Close') }}">
            <span aria-hidden="true">&times;</span>
        </button>

        <h2 class="angel-cart-toast__title">{{ _("Could not add to cart") }}</h2>
        <p class="angel-cart-toast__error-message" data-angel-cart-toast-error-message></p>

        <div class="angel-cart-toast__actions angel-cart-toast__actions--error">
            <button type="button" class="angel-cart-toast__btn angel-cart-toast__btn--ghost" data-angel-cart-toast-close>
                {{ _("Continue shopping") }}
            </button>
        </div>
    </div>
</div>

<script>
    window.angelCartToastLabels = {
        successTitle: {{ _("Added to shopping cart") | tojson }},
        errorTitle: {{ _("Could not add to cart") | tojson }},
        cartSummary: {{ _("You have {count} products in the cart for {total}") | tojson }},
        defaultError: {{ _("Failed to add to cart") | tojson }},
        chooseOptions: {{ _("Please choose product options first") | tojson }},
        chooseOptionNamed: {{ _("Please choose {name} before adding to cart") | tojson }},
        alreadyInCart: {{ _("This product is already in your cart. Quantity updated.") | tojson }},
        cartUnavailable: {{ _("Cart service not available") | tojson }},
        cartUrl: {{ url_for('cart_page') | tojson }},
        checkoutUrl: "/checkout"
    };
</script>
