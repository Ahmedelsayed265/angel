{% if product %}
{% set selected_product = product.selected_product %}
{% set has_preorder = product.effective_preorder_campaign is not none %}
{% set can_preorder = product.can_be_preordered %}
{% set is_in_stock = product.is_infinite or product.quantity > 0 or can_preorder %}
{% set is_out_of_stock = (product.is_infinite == false and product.quantity <= 0) and not can_preorder %}
{% set has_sale = product.formatted_sale_price is not none %}
{% set has_options = product.has_options or product.has_fields or product.product_class == 'dynamic_bundle' %}
{% set low_stock_threshold = store.settings.products.low_stock_quantity_threshold | default(10) %}
{% set show_low_stock = false %}
{% if is_in_stock and not product.is_infinite and product.quantity > 0 and product.quantity <= low_stock_threshold %}
  {% set show_low_stock = true %}
{% endif %}
{% if product.low_stock_quantity %}
  {% set show_low_stock = true %}
{% endif %}
{% set brand_name = "" %}
{% if product.categories and product.categories | length > 0 %}
  {% set brand_name = product.categories[0].name %}
{% endif %}

<article class="angel-cp-card{% if is_out_of_stock %} angel-cp-card--out{% endif %}">
  <a class="angel-cp-card__link" href="/products/{{ product.slug }}">
    <div class="angel-cp-card__media">
      {% if has_sale and product.discount_percentage %}
        <span class="angel-cp-card__badge angel-cp-card__badge--discount">{{ product.discount_percentage }}%</span>
      {% endif %}
      {% if show_low_stock %}
        <span class="angel-cp-card__badge angel-cp-card__badge--stock">على وشك النفاذ</span>
      {% endif %}
      <img
        class="angel-cp-card__img"
        src="{{ product.main_image.image.small if product.main_image else image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') }}"
        alt="{{ product.name }}"
        loading="lazy"
        width="200"
        height="200"
      >
    </div>

    <div class="angel-cp-card__body">
      {% if brand_name %}
        <span class="angel-cp-card__tag">{{ brand_name }}</span>
      {% endif %}
      <h3 class="angel-cp-card__title">{{ product.name }}</h3>
      {% if has_options %}
        <div class="angel-cp-card__swatches" aria-hidden="true">
          <span class="angel-cp-card__swatch"></span>
          <span class="angel-cp-card__swatch"></span>
          <span class="angel-cp-card__swatch"></span>
          <span class="angel-cp-card__swatch angel-cp-card__swatch--muted"></span>
        </div>
      {% endif %}
      <div class="angel-cp-card__prices">
        {% if has_sale %}
          <span class="angel-cp-card__price">{{ product.formatted_sale_price }}</span>
          <span class="angel-cp-card__price-old">{{ product.formatted_price }}</span>
        {% else %}
          <span class="angel-cp-card__price">{{ product.formatted_price }}</span>
        {% endif %}
      </div>
    </div>
  </a>

  {% if is_out_of_stock %}
    <a class="angel-cp-card__cta" href="/products/{{ product.slug }}">{{ _("Notify me when available") }}</a>
  {% elif has_options %}
    <a class="angel-cp-card__cta" href="/products/{{ product.slug }}">+ {{ _("add to cart") }}</a>
  {% else %}
    <button
      type="button"
      class="angel-cp-card__cta product-card-add-to-cart"
      onclick="event.preventDefault(); productCartAddToCart(this, '{{ product.id }}')"
    >
      <img class="add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="">
      + {{ _("add to cart") }}
    </button>
  {% endif %}
</article>
{% endif %}
