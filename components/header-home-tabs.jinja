{% set main_tabs_raw = safeget(settings, 'home_tabs_tabs', []) %}
{% set main_tabs =
    main_tabs_raw
    if main_tabs_raw is iterable and main_tabs_raw is not boolean and main_tabs_raw is not string
    else []
%}

{% if template == 'home' and settings.home_tabs_enabled != false and main_tabs | length > 0 %}
  <div class="container angel-header-home-tabs-wrap">
    <nav class="angel-header-home-tabs" role="tablist" aria-label="{{ _('Main tabs') }}">
      {% for item in main_tabs %}
        {% if loop.index <= 3 %}
          <button
            type="button"
            class="angel-header-home-tab{% if loop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{{ 'true' if loop.first else 'false' }}"
            data-hero-tab="{{ loop.index }}"
            {% if item.accent_color %}style="--hero-tab-accent: {{ item.accent_color }};"{% endif %}
          >
            {% if item.image %}
              <img
                class="angel-header-home-tab__image"
                src="{{ image_url(item.image, w=200, h=200, q=85) }}"
                alt=""
                width="24"
                height="24"
                loading="lazy"
                decoding="async"
              >
            {% endif %}
            <span class="angel-header-home-tab__label">{{ item.title if item.title else loop.index }}</span>
          </button>
        {% endif %}
      {% endfor %}
    </nav>
  </div>
{% endif %}
