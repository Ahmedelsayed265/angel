{% if settings.announcement_bar_display and (settings.announcement_bar_features_bar_list | length > 0) %}
    {% if not (settings.announcement_bar_page_display)
        or (template == 'home' and settings.announcement_bar_page_display == 'home')
        or settings.announcement_bar_page_display == 'all'
    %}
{% set items_list = settings.announcement_bar_features_bar_list %}

<div class="announcement-bar tp-bar" style="z-index: 4; {% if settings.announcement_bar_background_color %}background: {{ settings.announcement_bar_background_color }}{% endif %}; overflow: hidden; position: relative; width: 100%;">
    <div class="tp-mask" style="direction: ltr;">
        <div class="tp-marquee">
            {% for item in items_list %}
                <a href="{% if item.url %}{{ item.url }}{% else %}javascript:;{% endif %}" style="color: {{ item.text_color | default(settings.announcement_bar_text_color) }};">
                    {% if item.image %}
                        <img loading="lazy" width="26" height="26" class="lazy-img" src="{{ image_url(item.image) }}" alt="">
                    {% endif %}
                    {{ item.title }}
                </a>
            {% endfor %}
        </div>
        <div class="tp-marquee">
            {% for item in items_list %}
                <a href="{% if item.url %}{{ item.url }}{% else %}javascript:;{% endif %}" style="color: {{ item.text_color | default(settings.announcement_bar_text_color) }};">
                    {% if item.image %}
                        <img loading="lazy" width="26" height="26" class="lazy-img" src="{{ image_url(item.image) }}" alt="">
                    {% endif %}
                    {{ item.title }}
                </a>
            {% endfor %}
        </div>
    </div>
    <span class="icon-times-circle2 ab-close" style="position: absolute; top: 50%; right: 10px; transform: translateY(-50%); cursor: pointer; z-index: 5; {% if settings.announcement_bar_text_color %}color: {{ settings.announcement_bar_text_color }}{% endif %}" onclick="hideAnnouncementBar()"></span>
</div>

<script>
    function hideAnnouncementBar() {
        const bar = document.querySelector('.announcement-bar');
        if (bar) {
            bar.style.display = 'none';
        }
    }
</script>
    {% endif %}
{% endif %}
