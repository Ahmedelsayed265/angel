{% macro angel_slide_menu_image(menu) -%}
{%- set raw = safeget(menu, 'image', none) -%}
{%- if raw -%}
{%- if raw is string -%}{{ raw }}{%- elif safeget(raw, 'url', none) -%}{{ safeget(raw, 'url', '') }}{%- elif safeget(raw, 'image', none) -%}{{ safeget(raw, 'image', '') }}{%- endif -%}
{%- endif -%}
{%- endmacro %}

{% macro angel_slide_menu_badge(menu, settings) -%}
{%- for row in settings.sliding_menu_badges | default([]) -%}
{%- if row.menu_slug and menu.slug and row.menu_slug == menu.slug and row.badge_text -%}{{ row.badge_text }}{%- endif -%}
{%- endfor -%}
{%- endmacro %}

{% macro angel_slide_menu_icon_type(menu) -%}
{%- set slug = (menu.slug | default('', true)) | lower -%}
{%- set label = (menu.label | default('', true)) | lower -%}
{%- set menu_img = angel_slide_menu_image(menu) | trim -%}
{%- if menu_img -%}image
{%- elif slug == 'links' or 'روابط' in label -%}link
{%- elif 'customer' in slug or 'خدمة' in label or 'service' in slug -%}headset
{%- else -%}wing
{%- endif -%}
{%- endmacro %}

{% macro angel_slide_menu_link(menu, settings, is_sub) -%}
{%- set href = menu.url | localized_url if menu.resource_type != 'url' else menu.url -%}
{%- set has_children = menu.items | length > 0 -%}
{%- set badge = angel_slide_menu_badge(menu, settings) | trim -%}
{%- set icon_type = angel_slide_menu_icon_type(menu) -%}
{%- set menu_img = angel_slide_menu_image(menu) | trim -%}
<a
    href="{{ href }}"
    title="{{ menu.label }}"
    class="angel-slide-menu__link menu-link{% if is_sub %} angel-slide-menu__link--sub{% endif %}{% if has_children %} angel-slide-menu__link--parent{% endif %}"
    {% if has_children %}aria-haspopup="true"{% endif %}
>
    <span class=angel-slide-menu__media">
        {% if icon_type == 'image' and menu_img %}
            <img class="angel-slide-menu__thumb" src="{{ image_url(menu_img, w=96, h=96, q=90) }}" alt="" loading="lazy" decoding="async" width="40" height="40" />
        {% elif icon_type == 'link' %}
            <i class="sicon-link ltr:mr-2 rtl:ml-2 angel-slide-menu__sicon" aria-hidden="true"></i>
        {% elif icon_type == 'headset' %}
            <i class="sicon-headphones ltr:mr-2 rtl:ml-2 angel-slide-menu__sicon" aria-hidden="true"></i>
        {% else %}
            <span class="angel-slide-menu__wing" aria-hidden="true">
                {% if settings.header_logo %}
                    <img src="{{ image_url(settings.header_logo, h=56, q=90) }}" alt="" width="28" height="28" loading="lazy" decoding="async" />
                {% else %}
                    <img src="{{ image_url(store.logo, h=56, q=90) }}" alt="" width="28" height="28" loading="lazy" decoding="async" />
                {% endif %}
            </span>
        {% endif %}
    </span>
    <span class="angel-slide-menu__label-wrap">
        <span class="angel-slide-menu__label">{{ menu.label }}</span>
        {% if badge %}
            <span class="angel-slide-menu__badge">{{ badge }}</span>
        {% endif %}
    </span>
    {% if has_children %}
        <span class="angel-slide-menu__chevron" aria-hidden="true"></span>
    {% endif %}
</a>
{%- endmacro %}

{% macro angel_slide_menu_telegram_link(settings, store) -%}
{%- set t = (settings.sliding_menu_customer_service_telegram_url | default('', true)) | trim -%}
{%- if not t -%}
{%- set t = (safeget(store.settings.contact, 'telegram', '') | default('', true)) | trim -%}
{%- endif -%}
{%- if t -%}
{%- if t | length >= 4 and t[0:4] == 'http' -%}
{{ t }}
{%- else -%}
https://t.me/{{ t | replace('@', '') | replace('https://t.me/', '') | replace('http://t.me/', '') | replace('t.me/', '') }}
{%- endif -%}
{%- endif -%}
{%- endmacro %}

{% macro angel_slide_menu_telegram_label(settings, store) -%}
{%- set t = (settings.sliding_menu_customer_service_telegram_url | default('', true)) | trim -%}
{%- if not t -%}
{%- set t = (safeget(store.settings.contact, 'telegram', '') | default('', true)) | trim -%}
{%- endif -%}
{%- if t -%}
{%- if t | length >= 4 and t[0:4] == 'http' -%}
{{ t | replace('https://t.me/', '') | replace('http://t.me/', '') | replace('t.me/', '') }}
{%- else -%}
{{ t | replace('@', '') }}
{%- endif -%}
{%- endif -%}
{%- endmacro %}

{% macro angel_slide_menu_parent_link(label, icon_type) -%}
<a href="#" class="angel-slide-menu__link menu-link angel-slide-menu__link--parent" aria-haspopup="true" title="{{ label }}">
    <span class="">
        {% if icon_type == 'link' %}
            <i class="sicon-link ltr:mr-2 rtl:ml-2" aria-hidden="true"></i>
        {% elif icon_type == 'headset' %}
            <i class="sicon-headphones ltr:mr-2 rtl:ml-2" aria-hidden="true"></i>
        {% endif %}
    </span>
    <span class="angel-slide-menu__label-wrap">
        <span class="angel-slide-menu__label">{{ label }}</span>
    </span>
    <span class="angel-slide-menu__chevron" aria-hidden="true"></span>
</a>
{%- endmacro %}

{% macro angel_slide_menu_simple_link(label, href, is_sub) -%}
<a href="{{ href }}" class="angel-slide-menu__link menu-link{% if is_sub %} angel-slide-menu__link--sub angel-slide-menu__link--text-only{% endif %}" title="{{ label }}">
    <span class="angel-slide-menu__label-wrap">
        <span class="angel-slide-menu__label">{{ label }}</span>
    </span>
</a>
{%- endmacro %}

{% macro angel_slide_menu_support_card(href, label, icon) -%}
<a href="{{ href }}" class="angel-slide-menu__support-card angel-slide-menu__support-card--{{ icon }} menu-link"{% if href and href[0:4] == 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>
    <span class="angel-slide-menu__support-label">{{ label }}</span>
    <span class="angel-slide-menu__support-icon" aria-hidden="true">
        {% if icon == 'mobile' %}
            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
