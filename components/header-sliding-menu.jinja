{% macro angel_slide_menu_branch(items, settings, is_sub) -%}
{% for menu in items %}
    {% if menu.url %}
    <li class="slide-menu-ul-li angel-slide-menu__item{% if menu.items | length > 0 %} angel-slide-menu__item--has-children{% endif %}">
        {{ angel_slide_menu_link(menu, settings, is_sub) }}
        {% if menu.items | length > 0 %}
            <ul>
                {{ angel_slide_menu_branch(menu.items, settings, true) }}
            </ul>
        {% endif %}
    </li>
    {% endif %}
{% endfor %}
{%- endmacro %}

{% set header_options_raw = safeget(settings, 'header_options', []) %}
{% set header_options =
    header_options_raw
    if header_options_raw is iterable and header_options_raw is not boolean and header_options_raw is not string
    else []
%}
{% set multiple_languages = store.languages | length > 1 %}
{% set show_country = 'hide_country' not in header_options %}
{% set show_language = 'hide_language' not in header_options %}
{% set slide_show_region = show_country or (multiple_languages and show_language) %}

{% if settings.header_logo %}
    {% set slide_logo = settings.header_logo %}
{% else %}
    {% set slide_logo = store.logo %}
{% endif %}

{% set slide_cs_email = (settings.sliding_menu_customer_service_email | default('', true)) | trim %}
{% if not slide_cs_email %}
    {% set slide_cs_email = (store.settings.contact.email | default('', true)) | trim %}
{% endif %}
{% set slide_cs_phone = (settings.sliding_menu_customer_service_phone | default('', true)) | trim %}
{% if not slide_cs_phone %}
    {% set slide_cs_phone = (store.settings.contact.phone | default('', true)) | trim %}
{% endif %}
{% set slide_cs_mobile_url = (settings.sliding_menu_customer_service_mobile_url | default('', true)) | trim %}
{% if not slide_cs_mobile_url %}
    {% if store.settings.general.one_signal.ios_app_id %}
        {% set slide_cs_mobile_url = 'https://apps.apple.com/app/id' ~ store.settings.general.one_signal.ios_app_id %}
    {% elif store.settings.general.one_signal.android_package_name %}
        {% set slide_cs_mobile_url = 'https://play.google.com/store/apps/details?id=' ~ store.settings.general.one_signal.android_package_name %}
    {% endif %}
{% endif %}
{% set slide_tg_href %}{{ angel_slide_menu_telegram_link(settings, store) }}{% endset %}
{% set slide_tg_href = slide_tg_href | trim %}
{% set slide_tg_label %}{{ angel_slide_menu_telegram_label(settings, store) }}{% endset %}
{% set slide_tg_label = slide_tg_label | trim %}
{% set slide_useful_links = settings.sliding_menu_useful_links | default([]) %}
{% set slide_custom_links_raw = settings.sliding_menu_custom_links | default([]) %}
{% set slide_custom_links =
    slide_custom_links_raw
    if slide_custom_links_raw is iterable and slide_custom_links_raw is not boolean and slide_custom_links_raw is not string
    else []
%}
{% set slide_bg = (settings.sliding_menu_bg_color | default('', true)) | trim %}
{% set slide_has_support = not (settings.sliding_menu_customer_service_hide | default(false)) and (slide_cs_phone or slide_cs_email or slide_tg_href or slide_cs_mobile_url) %}
{% set slide_has_useful = not (settings.sliding_menu_useful_links_hide | default(false)) %}

<div id="sidenav-overlay" onclick="closeSlidingMenu()" aria-hidden="true"></div>
<nav class="slide-menu angel-slide-menu{% if slide_bg %} angel-slide-menu--custom-bg{% endif %}" id="sliding-menu" aria-label="{{ settings.sliding_menu_title | default(_('Main Menu'), true) }}"{% if slide_bg %} style="--angel-slide-menu-bg: {{ slide_bg }};"{% endif %}>
    <div class="angel-slide-menu__header">
        <div class="angel-slide-menu__topbar">
            <div class="angel-slide-menu__topbar-end">
                <span class="angel-slide-menu__title" id="angel-slide-menu-title">{{ settings.sliding_menu_title | default(_('Main Menu'), true) }}</span>
                <button type="button" class="angel-slide-menu__back" id="angel-slide-menu-back" hidden aria-label="{{ _('Back') }}">
                    <span class="angel-slide-menu__back-chevron" aria-hidden="true"></span>
                </button>
            </div>
            <button type="button" class="angel-slide-menu__close" onclick="closeSlidingMenu()" aria-label="{{ _('Close') }}">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>

        <div class="angel-slide-menu__brand">
            <a href="/" class="angel-slide-menu__brand-link">
                <img class="angel-slide-menu__brand-logo" src="{{ image_url(slide_logo, h=120, q=100) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
            </a>
            {% if settings.sliding_menu_tagline %}
                <p class="angel-slide-menu__brand-tagline">{{ settings.sliding_menu_tagline }}</p>
            {% else %}
                <p class="angel-slide-menu__brand-tagline">{{ _("Your trading partner on Salla platform") }}</p>
            {% endif %}
        </div>
    </div>

    <div class="angel-slide-menu__scroll">
        {% if slide_custom_links | length > 0 %}
        <div class="angel-slide-menu__custom-links" aria-label="{{ _('Links') }}">
            {% for link in slide_custom_links %}
                {% set link_title = (link.title | default('', true)) | trim %}
                {% set link_url = (link.url | default('', true)) | trim %}
                {% if link_title and link_url %}
                    {% set href = link_url | localized_url if link_url[0:1] == '/' else link_url %}
                    <a class="angel-slide-menu__custom-link{% if link.new_row | default(false) %} is-full{% endif %}" href="{{ href }}"{% if href and href[0:4] == 'http' %} target="_blank" rel="noopener noreferrer"{% endif %}>
                        {% if link.image %}
                            <img class="angel-slide-menu__custom-img" src="{{ image_url(link.image, h=96, q=90) }}" alt="" loading="lazy" decoding="async" />
                        {% endif %}
                        <span class="angel-slide-menu__custom-text">{{ link_title }}</span>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}
        <ul class="angel-slide-menu__list">
            {{ angel_slide_menu_branch(store.settings.menus.main_menu.items, settings, false) }}
            {% if slide_has_useful %}
                {% set useful_title = settings.sliding_menu_useful_links_title | default(_('Links of interest'), true) %}
                <li class="slide-menu-ul-li angel-slide-menu__item angel-slide-menu__item--has-children">
                    {{ angel_slide_menu_parent_link(useful_title, 'link') }}
                    <ul class="angel-slide-menu__subpanel">
                        {% if slide_useful_links | length > 0 %}
                            {% for link in slide_useful_links %}
                                {% set link_title = (link.title | default('', true)) | trim %}
                                {% set link_url = (link.url | default('', true)) | trim %}
                                {% if link_title and link_url %}
                                <li class="slide-menu-ul-li angel-slide-menu__item">
                                    {{ angel_slide_menu_simple_link(link_title, link_url | localized_url if link_url[0:1] == '/' else link_url, true) }}
                                </li>
                                {% endif %}
                            {% endfor %}
                        {% else %}
                            <li class="slide-menu-ul-li angel-slide-menu__item">
                                {{ angel_slide_menu_simple_link(_('Blog'), '/blogs' | localized_url, true) }}
                            </li>
                        {% endif %}
                    </ul>
                </li>
            {% endif %}

            {% if slide_has_support %}
                {% set support_title = settings.sliding_menu_customer_service_title | default(_('Customer service'), true) %}
                <li class="slide-menu-ul-li angel-slide-menu__item angel-slide-menu__item--has-children">
                    {{ angel_slide_menu_parent_link(support_title, 'headset') }}
                    <ul class="angel-slide-menu__subpanel angel-slide-menu__subpanel--support" data-angel-panel="support">
                        {% if slide_cs_phone %}
                            <li class="slide-menu-ul-li angel-slide-menu__support-item">
                                {{ angel_slide_menu_support_card('tel:' ~ slide_cs_phone, slide_cs_phone, 'mobile') }}
                            </li>
                            <li class="slide-menu-ul-li angel-slide-menu__support-item">
                                {{ angel_slide_menu_support_card('tel:' ~ slide_cs_phone, slide_cs_phone, 'phone') }}
                            </li>
                        {% elif slide_cs_mobile_url %}
                            <li class="slide-menu-ul-li angel-slide-menu__support-item">
                                {{ angel_slide_menu_support_card(slide_cs_mobile_url, _('Mobile app'), 'mobile') }}
                            </li>
                        {% endif %}
                        {% if slide_cs_email %}
                            <li class="slide-menu-ul-li angel-slide-menu__support-item">
                                {{ angel_slide_menu_support_card('mailto:' ~ slide_cs_email, slide_cs_email, 'email') }}
                            </li>
                        {% endif %}
                        {% if slide_tg_href %}
                            <li class="slide-menu-ul-li angel-slide-menu__support-item">
                                {{ angel_slide_menu_support_card(slide_tg_href, slide_tg_label or _('Telegram'), 'telegram') }}
                            </li>
                        {% endif %}
                    </ul>
                </li>
            {% endif %}
            {% if slide_show_region %}
                <li class="slide-menu-ul-li angel-slide-menu__item angel-slide-menu__item--region">
                    <button type="button" class="angel-slide-menu__link angel-slide-menu__link--region menu-link" onclick="zidOpenRegionSettingDialog()" aria-label="{{ _('Change country or language') }}">
                        <span class="">
                            <i class="sicon-dollar-coin-stack ltr:mr-2 rtl:ml-2" aria-hidden="true"></i>
                        </span>
                        <span class="angel-slide-menu__label-wrap">
                            <span class="angel-slide-menu__label">{{ _('Currency') }}</span>
                        </span>
                    </button>
                </li>
            {% endif %}
        </ul>
    </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function () {
    function cleanUrl(url) {
        if (!url) return url;
        if (url.startsWith('//')) {
            url = '/' + url.slice(2);
        }
        url = url.replace(/([^:]\/)\/+/g, '$1');
        if (url !== '/' && url.endsWith('/')) {
            url = url.slice(0, -1);
        }
        return url;
    }

    document.querySelectorAll('#sliding-menu .menu-link').forEach(function (link) {
        var href = link.getAttribute('href');
        if (href && href !== '#') {
            link.setAttribute('href', cleanUrl(href));
        }
    });

    /* Keep menu list inside scroll area after SlideMenu initializes */
    function angelSlideMenuMountScroll() {
        var nav = document.getElementById('sliding-menu');
        if (!nav) return;
        var scroll = nav.querySelector('.angel-slide-menu__scroll');
        var slider = nav.querySelector(':scope > .slide-menu__slider');
        if (scroll && slider && slider.parentElement === nav) {
            scroll.appendChild(slider);
        }
    }

    var nav = document.getElementById('sliding-menu');
    var titleEl = document.getElementById('angel-slide-menu-title');
    var backBtn = document.getElementById('angel-slide-menu-back');
    var rootTitle = titleEl ? titleEl.textContent.trim() : '';

    function angelSlideMenuSlider() {
        if (!nav) return null;
        return nav.querySelector('.angel-slide-menu__scroll .slide-menu__slider') || nav.querySelector('.slide-menu__slider');
    }

    function angelSlideMenuVisibleBacklink() {
        if (!nav) return null;
        var links = nav.querySelectorAll('.slide-menu__backlink');
        for (var i = 0; i < links.length; i++) {
            var link = links[i];
            if (link.offsetParent !== null && link.getClientRects().length) {
                return link;
            }
        }
        return links.length ? links[links.length - 1] : null;
    }

    function angelSlideMenuBacklinkTitle(backlink) {
        if (!backlink) return '';
        var clone = backlink.cloneNode(true);
        clone.querySelectorAll('.slide-menu-arrow, .slide-menu-arrow-back, .slide-menu__decorator').forEach(function (node) {
            node.remove();
        });
        return clone.textContent.replace(/\s+/g, ' ').trim();
    }

    function angelSlideMenuEnterSub(label) {
        if (!nav || !label) return;
        nav.classList.add('angel-slide-menu--sub');
        if (titleEl) titleEl.textContent = label;
        if (backBtn) backBtn.hidden = false;
    }

    function angelSlideMenuExitSub() {
        if (!nav) return;
        nav.classList.remove('angel-slide-menu--sub', 'angel-slide-menu--support');
        if (titleEl) titleEl.textContent = rootTitle;
        if (backBtn) backBtn.hidden = true;
    }

    function angelSlideMenuSyncHeader() {
        var backlink = angelSlideMenuVisibleBacklink();
        var slider = angelSlideMenuSlider();
        var tx = slider ? window.getComputedStyle(slider).transform : 'none';
        var atRoot = !slider || tx === 'none' || tx === 'matrix(1, 0, 0, 1, 0, 0)';

        if (atRoot || !backlink) {
            angelSlideMenuExitSub();
            return;
        }

        var label = angelSlideMenuBacklinkTitle(backlink);
        if (label) {
            angelSlideMenuEnterSub(label);
        }
    }

    if (backBtn) {
        backBtn.addEventListener('click', function (event) {
            event.preventDefault();
            var backlink = angelSlideMenuVisibleBacklink();
            if (backlink) {
                backlink.click();
            }
        });
    }

    function angelSlideMenuBind() {
        angelSlideMenuMountScroll();
        var sliderNode = angelSlideMenuSlider();
        if (sliderNode && !sliderNode.__angelSlideMenuObserved) {
            sliderNode.__angelSlideMenuObserved = true;
            new MutationObserver(angelSlideMenuSyncHeader).observe(sliderNode, {
                attributes: true,
                attributeFilter: ['style'],
            });
        }
        angelSlideMenuSyncHeader();
    }

    if (nav) {
        nav.addEventListener('click', function (event) {
            var parentLink = event.target.closest('.angel-slide-menu__link--parent');
            if (parentLink && nav.contains(parentLink)) {
                var labelNode = parentLink.querySelector('.angel-slide-menu__label');
                var label = labelNode ? labelNode.textContent.trim() : '';
                var subpanel = parentLink.parentElement ? parentLink.parentElement.querySelector(':scope > ul') : null;
                if (label) {
                    angelSlideMenuEnterSub(label);
                }
                nav.classList.toggle('angel-slide-menu--support', !!(subpanel && subpanel.getAttribute('data-angel-panel') === 'support'));
                window.setTimeout(angelSlideMenuSyncHeader, 320);
            }

            if (event.target.closest('.slide-menu__backlink')) {
                window.setTimeout(angelSlideMenuSyncHeader, 320);
            }
        });

        nav.addEventListener('sm.close', angelSlideMenuExitSub);
    }

    function angelSlideMenuWaitReady(attempt) {
        if (nav && (nav.querySelector('.slide-menu__slider') || window.slidingMenu)) {
            angelSlideMenuBind();
            return;
        }
        if ((attempt || 0) < 40) {
            window.setTimeout(function () {
                angelSlideMenuWaitReady((attempt || 0) + 1);
            }, 50);
        }
    }

    angelSlideMenuWaitReady(0);
    document.addEventListener('sm.open', angelSlideMenuBind);
});

document.addEventListener('zid-customer-fetched', function () {});
</script>
