{% set media_items = product.selected_product.media | default([]) %}
{% set share_url = product.html_url | default('', true) %}
{% set share_title = product.name | striptags %}
{% set pp_hide_badges = settings.product_page_hide_badges | default(false) %}
{% set pp_enable_zoom = settings.product_page_enable_zoom | default(true) %}
{% set pp_hide_thumbs = settings.product_page_hide_thumbs | default(false) %}
<div class="angel-product-gallery" id="angel-product-gallery" data-media-count="{{ media_items | length }}" data-video-icon="{{ 'video-play.svg' | asset_url }}" data-share-url="{{ share_url }}" data-share-title="{{ share_title | e }}" data-share-copied="{{ _('Link copied') | e }}">
    <div class="angel-product-gallery__stage {% if media_items | length <= 0 %}angel-product-gallery__stage--empty{% endif %}">
        {% if product.low_stock_quantity and product.selected_product.in_stock %}
            <span class="angel-product-gallery__low-stock">{{ _("Almost out of stock") }}</span>
        {% endif %}
        {% if not pp_hide_badges and (product.badge or product.discount_percentage) %}
            <span class="angel-product-gallery__badge">{{ _("Sale") }}</span>
        {% endif %}

        <div class="angel-product-gallery__actions" id="angel-product-gallery-actions">
            <div class="angel-product-gallery__actions-default" data-share-default>
                {% if store.settings.products.wishlist_enabled == true %}
                    <span class="angel-product-gallery__action angel-product-gallery__action--wishlist add-to-wishlist" data-wishlist-id="{{ product.id }}">
                        {% if not session.is_guest %}
                            <a class="icon-heart-mask" onclick="addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Wishlist') }}"></a>
                        {% else %}
                            <a class="icon-heart-mask" href="{{ url_for('login_page', query_params={'redirect_to': session.path}) }}" aria-label="{{ _('Wishlist') }}"></a>
                        {% endif %}
                        <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="" />
                    </span>
                {% endif %}
                <button type="button" class="angel-product-gallery__action" data-share-open aria-label="{{ _('share product') }}" aria-expanded="false">
                    <svg class="angel-product-gallery__action-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true">
                        <path fill="currentColor" d="M26.667 21.333c-1.699 0-3.196 0.812-4.173 2.052l-11.912-5.211c0.044-0.276 0.085-0.553 0.085-0.841 0-0.472-0.081-0.923-0.197-1.359l12.361-6.952c0.971 1.009 2.328 1.644 3.836 1.644 2.941 0 5.333-2.392 5.333-5.333s-2.392-5.333-5.333-5.333-5.333 2.392-5.333 5.333c0 0.472 0.081 0.923 0.197 1.359l-12.361 6.952c-0.971-1.009-2.328-1.644-3.836-1.644-2.941 0-5.333 2.392-5.333 5.333s2.392 5.333 5.333 5.333c1.699 0 3.196-0.812 4.173-2.052l11.912 5.211c-0.044 0.276-0.085 0.553-0.085 0.841 0 2.941 2.392 5.333 5.333 5.333s5.333-2.392 5.333-5.333-2.392-5.333-5.333-5.333zM26.667 2.667c1.471 0 2.667 1.196 2.667 2.667s-1.196 2.667-2.667 2.667-2.667-1.196-2.667-2.667 1.196-2.667 2.667-2.667zM5.333 20c-1.471 0-2.667-1.196-2.667-2.667s1.196-2.667 2.667-2.667 2.667 1.196 2.667 2.667-1.196 2.667-2.667 2.667zM26.667 29.333c-1.471 0-2.667-1.196-2.667-2.667s1.196-2.667 2.667-2.667 2.667 1.196 2.667 2.667-1.196 2.667-2.667 2.667z"></path>
                    </svg>
                </button>
            </div>

            <div class="angel-product-gallery__share-panel" data-share-panel hidden>
                <div class="angel-product-gallery__actions-row">
                    {% if store.settings.products.wishlist_enabled == true %}
                        <span class="angel-product-gallery__action angel-product-gallery__action--wishlist add-to-wishlist" data-wishlist-id="{{ product.id }}">
                            {% if not session.is_guest %}
                                <a class="icon-heart-mask" onclick="addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Wishlist') }}"></a>
                            {% else %}
                                <a class="icon-heart-mask" href="{{ url_for('login_page', query_params={'redirect_to': session.path}) }}" aria-label="{{ _('Wishlist') }}"></a>
                            {% endif %}
                            <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="" />
                        </span>
                    {% endif %}
                    <button type="button" class="angel-product-gallery__action" data-share-close aria-label="{{ _('Close') }}">
                        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32">
                            <title>cancel</title>
                            <path fill="white" d="M17.885 16l7.057-7.057c0.521-0.521 0.521-1.364 0-1.885s-1.364-0.521-1.885 0l-7.057 7.057-7.057-7.057c-0.521-0.521-1.364-0.521-1.885 0s-0.521 1.364 0 1.885l7.057 7.057-7.057 7.057c-0.521 0.521-0.521 1.364 0 1.885 0.26 0.26 0.601 0.391 0.943 0.391s0.683-0.131 0.943-0.391l7.057-7.057 7.057 7.057c0.26 0.26 0.601 0.391 0.943 0.391s0.683-0.131 0.943-0.391c0.521-0.521 0.521-1.364 0-1.885z"></path>
                        </svg>
                    </button>
                </div>
                <nav class="angel-product-gallery__share-menu" aria-label="{{ _('share product') }}">
                    <a class="angel-product-gallery__share-link" data-share="facebook" href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path fill="currentColor" d="M19 32h-6c-0.552 0-1-0.448-1-1v0-13h-3c-0.552 0-1-0.448-1-1v0-5c0-0.552 0.448-1 1-1v0h3v-4c0-3.866 3.134-7 7-7v0h4c0.552 0 1 0.448 1 1v0 5c0 0.552-0.448 1-1 1v0h-2c-0.552 0-1 0.448-1 1v0 3h5c0.552 0 1 0.448 1 1 0 0.134-0.026 0.262-0.074 0.379l0.002-0.007-2 5c-0.152 0.371-0.51 0.628-0.928 0.628h-3v13c0 0.552-0.448 1-1 1v0zM14 30h4v-13c0-0.552 0.448-1 1-1v0h3.324l1.2-3h-4.524c-0.552 0-1-0.448-1-1v0-4c0-1.657 1.343-3 3-3v0h1v-3h-3c-2.761 0-5 2.239-5 5v0 5c0 0.552-0.448 1-1 1v0h-3v3h3c0.552 0 1 0.448 1 1v0z"></path></svg>
                    </a>
                    <a class="angel-product-gallery__share-link" data-share="x" href="https://twitter.com/intent/tweet?text={{ share_title | urlencode }}&url={{ share_url | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="X">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </a>
                    <a class="angel-product-gallery__share-link" data-share="whatsapp" href="https://wa.me/?text={{ (share_title ~ ' ' ~ share_url) | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
                        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32">
                            <title>whatsapp</title>
                            <path fill="currentColor" d="M16 32c-0.008 0-0.018 0-0.028 0-3.1 0-5.993-0.887-8.439-2.421l0.066 0.039-7.2 2.3 2.336-6.964c-1.713-2.492-2.736-5.575-2.736-8.897 0-0.020 0-0.040 0-0.060v0.003c0.009-8.833 7.167-15.991 15.999-16h0.001c8.837 0 16 7.163 16 16s-7.163 16-16 16v0zM7.906 27.424l0.4 0.264c2.169 1.449 4.837 2.312 7.707 2.312 7.732 0 14-6.268 14-14s-6.268-14-14-14c-0.004 0-0.009 0-0.013 0h0.001c-7.729 0.008-13.992 6.271-14 13.999v0.001c-0 0.010-0 0.021-0 0.032 0 3.072 1 5.909 2.693 8.206l-0.027-0.038 0.304 0.416-1.4 4.2zM20.716 24.958c-1.684-0.131-3.237-0.574-4.641-1.271l0.073 0.033c-3.098-1.456-5.634-3.668-7.438-6.405l-0.042-0.067c-1.102-1.357-1.819-3.067-1.962-4.938l-0.002-0.030c-0.001-0.036-0.001-0.078-0.001-0.12 0-1.575 0.66-2.995 1.719-4l0.002-0.002c0.547-0.52 1.289-0.839 2.105-0.839 0.033 0 0.066 0.001 0.099 0.002l-0.005-0c0.2 0 0.378 0 0.542 0.018 0.016-0.001 0.035-0.001 0.054-0.001 0.815 0 1.502 0.549 1.711 1.298l0.003 0.012 0.324 0.782c0.376 0.906 0.858 2.068 0.942 2.244 0.144 0.251 0.23 0.552 0.23 0.873 0 0.286-0.068 0.557-0.188 0.797l0.005-0.010c-0.149 0.307-0.332 0.57-0.55 0.802l0.002-0.002c-0.148 0.168-0.248 0.274-0.346 0.378s-0.172 0.18-0.26 0.284c0.575 0.92 1.237 1.713 1.992 2.406l0.008 0.008c0.829 0.758 1.802 1.373 2.872 1.8l0.064 0.022c0.369-0.266 0.672-0.6 0.896-0.985l0.008-0.015 0.174-0.232c0.328-0.484 0.875-0.798 1.495-0.798 0.249 0 0.487 0.051 0.703 0.142l-0.012-0.004c0.492 0.168 2.922 1.372 2.946 1.384l0.228 0.11c0.415 0.149 0.758 0.417 0.996 0.763l0.004 0.007c0.107 0.349 0.169 0.75 0.169 1.166 0 0.591-0.125 1.153-0.349 1.661l0.010-0.026c-0.702 1.368-1.983 2.353-3.511 2.637l-0.031 0.005c-0.309 0.071-0.663 0.112-1.028 0.112-0.004 0-0.007 0-0.011 0h0.001zM10.632 9.318c-0.028-0.002-0.062-0.004-0.095-0.004-0.245 0-0.472 0.076-0.659 0.206l0.004-0.002c-0.726 0.651-1.18 1.591-1.18 2.638 0 0.044 0.001 0.087 0.002 0.13l-0-0.006c0.122 1.404 0.662 2.662 1.495 3.671l-0.009-0.011 0.12 0.168c1.627 2.491 3.865 4.46 6.504 5.723l0.096 0.041c3.136 1.288 3.916 1.124 4.426 1.014 0.87-0.159 1.601-0.656 2.067-1.347l0.007-0.011c0.12-0.316 0.204-0.682 0.237-1.063l0.001-0.015-0.040-0.018-0.256-0.124c-0.8-0.4-2.46-1.2-2.734-1.292l-0.058 0.184c-0.346 0.501-0.684 0.934-1.045 1.347l0.015-0.017c-0.344 0.349-0.821 0.565-1.349 0.565-0.28 0-0.546-0.061-0.785-0.17l0.012 0.005c-1.403-0.547-2.609-1.301-3.646-2.239l0.010 0.009c-0.975-0.891-1.81-1.912-2.486-3.039l-0.034-0.061c-0.152-0.244-0.242-0.54-0.242-0.857 0-0.463 0.191-0.88 0.499-1.178l0-0c0.13-0.162 0.264-0.302 0.4-0.444l0.236-0.256c0.091-0.096 0.177-0.201 0.254-0.311l0.006-0.009c-0.158-0.36-0.622-1.472-0.988-2.352l-0.322-0.772-0.038-0.086c-0.188-0.010-0.302-0.016-0.426-0.016zM12.462 12.442v0.012z"></path>
                        </svg>
                    </a>
                    <a class="angel-product-gallery__share-link" data-share="email" href="mailto:?subject={{ share_title | urlencode }}&body={{ share_url | urlencode }}" aria-label="{{ _('Email') }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path fill="currentColor" d="M28 2.667h-24c-2.205 0-4 1.795-4 4v18.667c0 2.205 1.795 4 4 4h24c2.205 0 4-1.795 4-4v-18.667c0-2.205-1.795-4-4-4zM29.333 25.333c0 0.735-0.599 1.333-1.333 1.333h-24c-0.735 0-1.333-0.599-1.333-1.333v-12.685l10.54 4.865c0.888 0.409 1.84 0.613 2.793 0.613s1.907-0.204 2.793-0.615l10.54-4.864zM29.333 9.711l-11.657 5.38c-1.065 0.492-2.288 0.492-3.353 0l-11.656-5.38v-3.044c0-0.735 0.599-1.333 1.333-1.333h24c0.735 0 1.333 0.599 1.333 1.333z"></path></svg>
                    </a>
                    <button type="button" class="angel-product-gallery__share-link" data-share="copy" aria-label="{{ _('Copy link') }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path fill="currentColor" d="M19.247 23.019l-4.189 4.189c-2.831 2.831-7.435 2.831-10.265 0-1.371-1.372-2.125-3.193-2.125-5.132s0.755-3.761 2.125-5.133l4.189-4.191c0.521-0.521 0.521-1.364 0-1.885s-1.364-0.521-1.885 0l-4.189 4.191c-1.875 1.875-2.907 4.367-2.907 7.019s1.032 5.143 2.907 7.017 4.368 2.907 7.019 2.907 5.143-1.032 7.017-2.908l4.189-4.189c0.521-0.521 0.521-1.364 0-1.885s-1.364-0.52-1.885 0.001zM22.276 9.724c-0.521-0.521-1.364-0.521-1.885 0l-10.667 10.667c-0.521 0.521-0.521 1.364 0 1.885 0.26 0.26 0.601 0.391 0.943 0.391s0.683-0.131 0.943-0.391l10.667-10.667c0.521-0.521 0.521-1.364 0-1.885zM29.093 2.908c-1.875-1.876-4.368-2.908-7.019-2.908s-5.143 1.032-7.017 2.908l-4.189 4.188c-0.521 0.521-0.521 1.364 0 1.885s1.364 0.521 1.885 0l4.189-4.189c2.831-2.831 7.435-2.831 10.265 0 1.371 1.372 2.125 3.193 2.125 5.132s-0.755 3.761-2.125 5.133l-4.189 4.191c-0.521 0.521-0.521 1.364 0 1.885 0.26 0.26 0.601 0.391 0.943 0.391s0.683-0.131 0.943-0.391l4.189-4.191c1.875-1.875 2.907-4.367 2.907-7.019s-1.032-5.143-2.907-7.016z"></path></svg>
                    </button>
                </nav>
            </div>
        </div>

        <div class="swiper angel-product-gallery__main {% if media_items | length <= 0 %}d-none{% endif %}" id="angel-product-gallery-main">
            <div class="swiper-wrapper" id="angel-product-gallery-main-wrapper">
                {% for image in media_items %}
                    <div class="swiper-slide">
                        {% if pp_enable_zoom %}
                        <button type="button" class="angel-product-gallery__zoom" data-gallery-index="{{ loop.index0 }}" aria-label="{{ _('View image') }}">
                            <img
                                src="{{ image.image.full_size }}"
                                alt="{{ image.alt_text | default(product.name, true) }}"
                                class="angel-product-gallery__img"
                                loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
                            />
                            {% if image.provider and image.link %}
                                <img
                                    class="angel-product-gallery__play"
                                    src="{{ 'video-play.svg' | asset_url }}"
                                    alt=""
                                    data-video-link="{{ image.link }}"
                                    onclick="event.stopPropagation(); showIframe(this, '{{ image.link }}');"
                                />
                            {% endif %}
                        </button>
                        {% else %}
                        <div class="angel-product-gallery__zoom" aria-label="{{ _('View image') }}">
                            <img
                                src="{{ image.image.full_size }}"
                                alt="{{ image.alt_text | default(product.name, true) }}"
                                class="angel-product-gallery__img"
                                loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
                            />
                        </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            <button type="button" class="angel-product-gallery__nav angel-product-gallery__nav--prev" id="angel-product-gallery-prev" aria-label="{{ _('Previous') }}">
                <span class="icon-keyboard_arrow_right angel-product-gallery__chevron angel-product-gallery__chevron--rtl" aria-hidden="true"></span>
                <span class="icon-keyboard_arrow_left angel-product-gallery__chevron angel-product-gallery__chevron--ltr" aria-hidden="true"></span>
            </button>
            <button type="button" class="angel-product-gallery__nav angel-product-gallery__nav--next" id="angel-product-gallery-next" aria-label="{{ _('Next') }}">
                <span class="icon-keyboard_arrow_left angel-product-gallery__chevron angel-product-gallery__chevron--rtl" aria-hidden="true"></span>
                <span class="icon-keyboard_arrow_right angel-product-gallery__chevron angel-product-gallery__chevron--ltr" aria-hidden="true"></span>
            </button>
            <div class="angel-product-gallery__pagination swiper-pagination" id="angel-product-gallery-pagination"></div>
        </div>

        {% if pp_enable_zoom %}
            <div class="angel-product-gallery__lens" id="angel-product-gallery-lens" aria-hidden="true">
                <img class="angel-product-gallery__lens-img" alt="" />
            </div>
        {% endif %}

        <div class="angel-product-gallery__empty {% if media_items | length > 0 %}d-none{% endif %}" id="angel-product-gallery-empty">
            <img src="{{ 'product-img.svg' | asset_url }}" alt="" width="120" height="120" />
        </div>
    </div>

    {% if not pp_hide_thumbs %}
        <div class="swiper angel-product-gallery__thumbs {% if media_items | length <= 1 %}d-none{% endif %}" id="angel-product-gallery-thumbs">
            <div class="swiper-wrapper" id="angel-product-gallery-thumbs-wrapper">
                {% for image in media_items %}
                    <div class="swiper-slide">
                        <button type="button" class="angel-product-gallery__thumb" data-index="{{ loop.index0 }}">
                            <img src="{{ image.image.medium }}" alt="" loading="lazy" />
                        </button>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>
