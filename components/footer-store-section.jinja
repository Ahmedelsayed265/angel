        </div>
        {% endif %}

        <div class="angel-footer-store__main footer-theme-bg-primary footer-theme-text-for-primary-bg">
            <div class="row angel-footer-store__main-row">
                <div class="col-12 col-sm-6 col-lg-3 angel-footer-store__col">
                    <div class="angel-footer-store__brand">
                        {% if settings.footer_brand_logo %}
                            <img class="angel-footer-store__brand-logo" src="{{ image_url(settings.footer_brand_logo, h=120, q=90) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
                        {% else %}
                            {% set cs_dark_logo = settings.color_system_dark_logo | default(none) %}
                            {% set cs_mode = (settings.color_system_theme_mode | default('light')) %}
                            {% set use_dark_logo = cs_mode == 'dark' or settings.color_system_force_dark_footer %}
                            {% if cs_mode == 'auto' and cs_dark_logo and not settings.color_system_force_dark_footer %}
                                <img class="angel-footer-store__brand-logo angel-footer-store__brand-logo--light" src="{{ image_url(store.logo, h=120, q=90) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
                                <img class="angel-footer-store__brand-logo angel-footer-store__brand-logo--dark d-none" src="{{ image_url(cs_dark_logo, h=120, q=90) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
                            {% elif use_dark_logo and cs_dark_logo %}
                                <img class="angel-footer-store__brand-logo" src="{{ image_url(cs_dark_logo, h=120, q=90) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
                            {% else %}
                                <img class="angel-footer-store__brand-logo" src="{{ image_url(store.logo, h=120, q=90) }}" alt="{{ store.name }}" loading="lazy" decoding="async" />
                            {% endif %}
                        {% endif %}
                        {% set footer_brand_subtitle = (settings.footer_brand_subtitle | default('متجر تجريبي - Demo Store', true)) | trim %}
                        {% if footer_brand_subtitle %}
                            <p class="angel-footer-store__brand-subtitle">{{ footer_brand_subtitle }}</p>
                        {% endif %}
                        {% if settings.about_us_title %}
                            <div class="angel-footer-store__brand-name">{{ settings.about_us_title }}</div>
                        {% endif %}
                        {% if settings.about_us_des %}
                            <p class="angel-footer-store__brand-tagline">{{ settings.about_us_des | safe }}</p>
                        {% endif %}
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-lg-3 angel-footer-store__col">
                    {% if not settings.links_1_hide %}
                        <div class="angel-footer-store__block">
                            <h3 class="angel-footer-store__heading">{{ settings.links_1_title }}</h3>
                            {% for link in settings.links_1_links | default([]) %}
                                <p class="angel-footer-store__link-line"><a href="{{ link.url }}">{{ link.title }}</a></p>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if not settings.links_2_hide %}
                        <div class="angel-footer-store__block angel-footer-store__block--spaced">
                            <h3 class="angel-footer-store__heading">{{ settings.links_2_title }}</h3>
                            {% for link in settings.links_2_links | default([]) %}
                                <p class="angel-footer-store__link-line"><a href="{{ link.url }}">{{ link.title }}</a></p>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {% if not settings.customer_service_hide %}
                <div class="col-12 col-sm-6 col-lg-3 angel-footer-store__col">
                    <div class="angel-footer-store__block">
                        <h3 class="angel-footer-store__heading">
                            {% if settings.customer_service_title %}{{ settings.customer_service_title }}{% else %}{{ _("Customer service") }}{% endif %}
                        </h3>
                        <div class="angel-footer-store__service-icons">
                            {% if cs_mobile_url %}
                                <a class="angel-footer-store__service-icon angel-footer-store__service-icon--mobile" href="{{ cs_mobile_url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ _('Mobile app') }}">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
                                        <path d="M15.053 27.613c0.133 0.12 0.28 0.213 0.44 0.28s0.333 0.107 0.507 0.107c0.36 0 0.693-0.135 0.947-0.387 0.12-0.135 0.213-0.28 0.28-0.44 0.080-0.16 0.107-0.333 0.107-0.507 0-0.347-0.147-0.695-0.387-0.947-0.507-0.493-1.387-0.493-1.893 0-0.12 0.12-0.213 0.267-0.28 0.44-0.067 0.16-0.107 0.333-0.107 0.507s0.040 0.347 0.107 0.507 0.16 0.305 0.28 0.44zM24 0h-16c-2.205 0-4 1.795-4 4v24c0 2.205 1.795 4 4 4h16c2.205 0 4-1.795 4-4v-24c0-2.205-1.795-4-4-4zM25.333 28c0 0.736-0.599 1.333-1.333 1.333h-16c-0.735 0-1.333-0.597-1.333-1.333v-4h18.667zM25.333 21.333h-18.667v-17.333c0-0.735 0.599-1.333 1.333-1.333h16c0.735 0 1.333 0.599 1.333 1.333z"></path>
                                    </svg>
                                </a>
                            {% endif %}
                            {% if cs_phone %}
                                <a class="angel-footer-store__service-icon angel-footer-store__service-icon--phone" href="tel:{{ cs_phone }}" aria-label="{{ _('Phone') }}">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
                                        <path d="M30.823 21.713l-3.883-3.883c-1.569-1.568-4.12-1.568-5.689 0l-2.568 2.568c-3.063-1.499-5.583-4.019-7.081-7.083l2.568-2.567c0.759-0.76 1.177-1.771 1.177-2.845s-0.419-2.084-1.179-2.844l-3.881-3.881c-1.52-1.521-4.171-1.521-5.689 0l-1.845 1.847c-2.22 2.219-3.183 5.407-2.573 8.527 1.98 10.144 10.125 18.292 20.269 20.271 0.616 0.121 1.236 0.18 1.849 0.18 2.492 0 4.896-0.972 6.677-2.752l1.847-1.847c1.568-1.571 1.568-4.121 0.001-5.691zM28.936 25.517l-1.845 1.847c-1.592 1.592-3.883 2.283-6.132 1.841-9.089-1.776-16.388-9.075-18.163-18.165-0.439-2.247 0.249-4.539 1.841-6.129l1.847-1.847c0.256-0.257 0.596-0.397 0.959-0.397s0.703 0.14 0.959 0.397l3.883 3.883c0.256 0.256 0.397 0.596 0.397 0.959s-0.141 0.703-0.397 0.96l-3.22 3.217c-0.383 0.384-0.496 0.959-0.287 1.457 1.813 4.339 5.343 7.868 9.683 9.684 0.497 0.207 1.073 0.095 1.457-0.288l3.22-3.22c0.529-0.529 1.389-0.528 1.917 0l3.881 3.883c0.528 0.529 0.528 1.389 0 1.919z"></path>
                                    </svg>
                                </a>
                            {% endif %}
                            {% if cs_email %}
                                <a class="angel-footer-store__service-icon angel-footer-store__service-icon--email" href="mailto:{{ cs_email }}" aria-label="{{ _('Email') }}">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
                                        <path d="M28 2.667h-24c-2.205 0-4 1.795-4 4v18.667c0 2.205 1.795 4 4 4h24c2.205 0 4-1.795 4-4v-18.667c0-2.205-1.795-4-4-4zM29.333 25.333c0 0.735-0.599 1.333-1.333 1.333h-24c-0.735 0-1.333-0.599-1.333-1.333v-12.685l10.54 4.865c0.888 0.409 1.84 0.613 2.793 0.613s1.907-0.204 2.793-0.615l10.54-4.864zM29.333 9.711l-11.657 5.38c-1.065 0.492-2.288 0.492-3.353 0l-11.656-5.38v-3.044c0-0.735 0.599-1.333 1.333-1.333h24c0.735 0 1.333 0.599 1.333 1.333z"></path>
                                    </svg>
                                </a>
                            {% endif %}
                            {% if tg_href %}
                                <a class="angel-footer-store__service-icon angel-footer-store__service-icon--telegram" href="{{ tg_href }}" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
                                        <path d="M31.5 0.482c0.375 0.268 0.554 0.696 0.482 1.143l-4.571 27.429c-0.054 0.339-0.268 0.625-0.571 0.804-0.161 0.089-0.357 0.143-0.554 0.143-0.143 0-0.286-0.036-0.429-0.089l-9.411-3.839-5.321 5.839c-0.214 0.25-0.518 0.375-0.839 0.375-0.143 0-0.286-0.018-0.411-0.071-0.446-0.179-0.732-0.607-0.732-1.071v-8.071l-8.429-3.446c-0.411-0.161-0.679-0.536-0.714-0.982-0.036-0.429 0.196-0.839 0.571-1.054l29.714-17.143c0.375-0.232 0.857-0.214 1.214 0.036zM25.393 27.25l3.946-23.625-25.607 14.768 6 2.446 15.411-11.411-8.536 14.232z"></path>
                                    </svg>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endif %}

                <div class="col-12 col-sm-6 col-lg-3 angel-footer-store__col">
                    <div class="angel-footer-store__block">
                        {% if not settings.app_section_hide %}
                        <h3 class="angel-footer-store__heading">
                            {% if settings.app_section_title %}{{ settings.app_section_title }}{% else %}{{ _("Store app") }}{% endif %}
                        </h3>
                        {% set app_google_play_url = (settings.app_section_google_play_url | default('', true)) | trim %}
                        {% if not app_google_play_url and store.settings.general.one_signal.android_package_name %}
                            {% set app_google_play_url = 'https://play.google.com/store/apps/details?id=' ~ store.settings.general.one_signal.android_package_name %}
                        {% endif %}
                        {% set app_store_url = (settings.app_section_app_store_url | default('', true)) | trim %}
                        {% if not app_store_url and store.settings.general.one_signal.ios_app_id %}
                            {% set app_store_url = 'https://apps.apple.com/app/id' ~ store.settings.general.one_signal.ios_app_id %}
                        {% endif %}
                        {% if app_google_play_url or app_store_url %}
                            <div class="angel-footer-store__app-badges">
                                {% if app_store_url %}
                                    <a class="angel-footer-store__app-badge" href="{{ app_store_url }}" target="_blank" rel="noopener noreferrer">
                                        {% if settings.app_section_app_store_image %}
                                            <img src="{{ image_url(settings.app_section_app_store_image, h=80, q=90) }}" alt="{{ _('Download on the App Store') }}" loading="lazy" decoding="async" width="135" height="40" />
                                        {% else %}
                                            <img src="{{ 'app-store.svg' | asset_url }}" alt="{{ _('Download on the App Store') }}" loading="lazy" decoding="async" width="135" height="40" />
                                        {% endif %}
                                    </a>
                                {% endif %}
                                {% if app_google_play_url %}
                                    <a class="angel-footer-store__app-badge" href="{{ app_google_play_url }}" target="_blank" rel="noopener noreferrer">
                                        {% if settings.app_section_google_play_image %}
                                            <img src="{{ image_url(settings.app_section_google_play_image, h=80, q=90) }}" alt="{{ _('Get it on Google Play') }}" loading="lazy" decoding="async" width="135" height="40" />
                                        {% else %}
                                            <img src="{{ 'google-play.svg' | asset_url }}" alt="{{ _('Get it on Google Play') }}" loading="lazy" decoding="async" width="135" height="40" />
                                        {% endif %}
                                    </a>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% endif %}

                        {% if store.settings.general.tax_settings.tax_number %}
                            <div class="angel-footer-store__vat-inline">
                                {% if store.settings.general.tax_settings.is_certificate_visible %}
                                    <a class="angel-footer-store__vat-logo" {% if store.settings.general.tax_settings.tax_registration_certificate %}href="{{ store.settings.general.tax_settings.tax_registration_certificate }}" target="_blank" rel="noopener noreferrer"{% endif %}>
                                        <img src="{{ 'vat-certificate.png' | asset_url }}" alt="{{ _('VAT') }}" loading="lazy" width="48" height="48" />
                                    </a>
                                {% endif %}
                                <div class="angel-footer-store__vat-text">
                                    <span class="angel-footer-store__vat-label">{{ _("The VAT number:") }}</span>
                                    <span class="angel-footer-store__vat-num">{{ store.settings.general.tax_settings.tax_number }}</span>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {% if store.settings.general.business_address.show_location %}
                <div class="row mt-4">
                    <div class="col-12">
                        <h3 class="angel-footer-store__heading">{% if settings.business_location_title %}{{ settings.business_location_title }}{% else %}{{ _("Our place") }}{% endif %}</h3>
                        <p class="angel-footer-store__link-line mb-0">
                            <a {% if store.settings.general.business_address.latitude %} target="_blank" rel="noopener noreferrer" href="https://maps.google.com/?q={{ store.settings.general.business_address.latitude }},{{ store.settings.general.business_address.longitude }}" {% endif %}>
                                <i class="icon-map-marker-alt"></i>
                                {{ store.settings.general.business_address.street }}
                                — {{ store.settings.general.business_address.city.country.name }}, {{ store.settings.general.business_address.city.name }}, {{ store.settings.general.business_address.district }}
                            </a>
                        </p>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="angel-footer-store__payments footer-theme-bg-primary footer-theme-text-for-primary-bg">
                <div class="angel-footer-store__bottom-maroof">
                    {% if store.settings.contact.business_center %}
                    <div class="angel-footer-store__maroof-item">
                        <a class="angel-footer-store__maroof-link" href="https://eauthenticate.saudibusiness.gov.sa/certificate-details/{{ store.settings.contact.business_center }}" target="_blank" rel="noopener noreferrer">
                            <img src="{{ 'business_center.png' | asset_url }}" alt="{{ _('Documented in the Business Platform') }}" loading="lazy" width="120" height="36" />
                        </a>
                        <span class="angel-footer-store__maroof-text">{{ _("Documented in the Business Platform") }}</span>
                    </div>
                    {% endif %}
                    {% if store.settings.general.commercial_registration_number %}
                        <div class="angel-footer-store__cr-line">
                            <span>{{ _("The commercial register number:") }}</span>
                            <span>{{ store.settings.general.commercial_registration_number }}</span>
                        </div>
                    {% endif %}
                </div>
            <div class="angel-footer-store__pay-icons">
                {% for logo_item in ft_extra_logos %}
                    {% if logo_item.image %}
                        {% set logo_href = (logo_item.url | default('', true)) | trim %}
                        {% if logo_href %}
                            <a href="{{ logo_href }}" class="angel-footer-store__extra-logo-link" target="_blank" rel="noopener noreferrer">
                                <img src="{{ image_url(logo_item.image, h=80, q=90) }}" alt="" loading="lazy" class="angel-footer-store__extra-logo" />
                            </a>
                        {% else %}
                            <span class="angel-footer-store__extra-logo-link">
                                <img src="{{ image_url(logo_item.image, h=80, q=90) }}" alt="" loading="lazy" class="angel-footer-store__extra-logo" />
                            </span>
                        {% endif %}
                    {% endif %}
                {% endfor %}
                {% if ft_show_payments %}
                    {% for shipping_method in store.settings.checkout.shipping_methods | default([]) %}
                        <a href="/shipping-and-payment" class="angel-footer-store__pay-link">
                            <img src="{{ image_url(shipping_method.icon, h=80, q=100) }}" alt="" loading="lazy" height="24" />
                        </a>
                    {% endfor %}
                    {% for payment_method in store.settings.checkout.payment_methods | default([]) %}
                        <a href="/shipping-and-payment" class="angel-footer-store__pay-link">
                            <img src="{{ image_url(payment_method.icon, h=80, q=100) }}" alt="" loading="lazy" height="24" />
                        </a>
                    {% endfor %}
                {% endif %}
            </div>
            <span class="footer-copyrights">{{ store.settings.branding.copyrights | safe }}</span>
        </div>
    </div>
</div>

<script>
(function () {
    var btn = document.getElementById('angel-footer-back-top');
    if (btn) {
        btn.addEventListener('click', function () {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }
    var form = document.querySelector('.angel-footer-store__newsletter-form[data-angel-newsletter-missing-action="1"]');
    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var msg = {{ _("Set the newsletter form URL in Layout → Footer or Footer section → Newsletter.") | tojson }};
            if (window.zid && window.zid.toaster && typeof window.zid.toaster.showSuccess === 'function') {
                window.zid.toaster.showSuccess(msg);
            } else {
                window.alert(msg);
            }
        });
    }
})();
</script>
