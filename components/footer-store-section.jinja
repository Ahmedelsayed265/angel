{% macro angel_footer_youtube_link(settings, store) -%}
{%- set u = (settings.newsletter_youtube_url | default('', true)) | trim -%}
{%- if u -%}
{{ u }}
{%- else -%}
{%- set cy = (safeget(store.settings.contact, 'youtube', '') | default('', true)) | trim -%}
{%- if cy -%}
{%- if cy | length >= 4 and cy[0:4] == 'http' -%}
{{ cy }}
{%- else -%}
https://www.youtube.com/{{ cy }}
{%- endif -%}
{%- endif -%}
{%- endif -%}
{%- endmacro %}

{% macro angel_footer_telegram_link(settings, store) -%}
{%- set t = (settings.customer_service_telegram_url | default('', true)) | trim -%}
{%- if not t -%}
{%- set t = (safeget(store.settings.contact, 'telegram', '') | default('', true)) | trim -%}
{%- endif -%}
{%- if t -%}
{%- if t | length >= 4 and t[0:4] == 'http' -%}
{{ t }}
{%- else -%}
https://t.me/{{ t | replace('@', '') | replace('https://t.me/', '') | replace('http://t.me/', '') | replace('t.me/', '') }}
{%- endif -%}
{%- endif -%}
{%- endmacro %}

{% set ft_bg = (settings.layout_footer_bg_color | default('', true)) | trim %}
{% set ft_logo_scale_raw = (settings.layout_footer_logo_scale | default('2.5', true)) | trim %}
{% set ft_logo_scale = ft_logo_scale_raw if ft_logo_scale_raw else '2.5' %}
{% set ft_show_payments = settings.layout_footer_show_payment_icons | default(false) %}
{% set ft_hide_back_top = settings.layout_footer_hide_back_to_top | default(false) %}
{% set ft_compact = settings.layout_footer_compact | default(false) %}
{% set ft_newsletter_enabled = settings.layout_footer_newsletter_enabled | default(true) %}
{% set ft_extra_logos_raw = safeget(settings, 'layout_footer_extra_logos', []) %}
{% set ft_extra_logos =
    ft_extra_logos_raw
    if ft_extra_logos_raw is iterable and ft_extra_logos_raw is not boolean and ft_extra_logos_raw is not string
    else []
%}
{% set ft_newsletter_url = (settings.layout_footer_newsletter_form_url | default('', true)) | trim %}
{% set section_newsletter_url = (settings.newsletter_form_action_url | default('', true)) | trim %}
{% set newsletter_form_url = ft_newsletter_url or section_newsletter_url %}
{% set newsletter_hidden = settings.newsletter_hide | default(false) or ft_compact or not ft_newsletter_enabled %}
{% set youtube_href %}{{ angel_footer_youtube_link(settings, store) }}{% endset %}
{% set youtube_href = youtube_href | trim %}
{% set tg_href %}{{ angel_footer_telegram_link(settings, store) }}{% endset %}
{% set tg_href = tg_href | trim %}
{% set cs_email = (settings.customer_service_email | default('', true)) | trim %}
{% if not cs_email %}
    {% set cs_email = (store.settings.contact.email | default('', true)) | trim %}
{% endif %}
{% set cs_phone = (settings.customer_service_phone | default('', true)) | trim %}
{% if not cs_phone %}
    {% set cs_phone = (store.settings.contact.phone | default('', true)) | trim %}
{% endif %}
{% set cs_mobile_url = (settings.customer_service_mobile_url | default('', true)) | trim %}
{% if not cs_mobile_url %}
    {% if store.settings.general.one_signal.ios_app_id %}
        {% set cs_mobile_url = 'https://apps.apple.com/app/id' ~ store.settings.general.one_signal.ios_app_id %}
    {% elif store.settings.general.one_signal.android_package_name %}
        {% set cs_mobile_url = 'https://play.google.com/store/apps/details?id=' ~ store.settings.general.one_signal.android_package_name %}
    {% endif %}
{% endif %}

<div
    class="angel-footer-store{% if ft_compact %} angel-footer-store--compact{% endif %}{% if ft_bg %} angel-footer-store--custom-bg{% endif %}"
    style="--angel-footer-logo-scale: {{ ft_logo_scale | e }};{% if ft_bg %} --angel-footer-bg: {{ ft_bg }};{% endif %}"
>
    <div class="container angel-footer-store__container">
        {% if not ft_hide_back_top %}
        <button type="button" class="angel-footer-store__back-top" id="angel-footer-back-top">
            <span class="angel-footer-store__back-top-text">{{ _("Back to top") }}</span>
            <i class="sicon-arrow-up icon angel-footer-store__back-top-icon" aria-hidden="true"></i>
        </button>
        {% endif %}

        {% if not newsletter_hidden %}
        <div class="angel-footer-store__newsletter-band">
            <div class="angel-footer-store__newsletter-inner">
                <div class="angel-footer-store__newsletter-content">
                    <div class="angel-footer-store__newsletter-copy">
                        {% if settings.newsletter_title %}
                            <h2 class="angel-footer-store__newsletter-title">{{ settings.newsletter_title }}</h2>
                        {% endif %}
                        {% if settings.newsletter_description %}
                            <p class="angel-footer-store__newsletter-desc">{{ settings.newsletter_description | safe }}</p>
                        {% endif %}
                    </div>
                    <form
                        class="angel-footer-store__newsletter-form"
                        method="post"
                        {% if newsletter_form_url %}action="{{ newsletter_form_url }}"{% else %}data-angel-newsletter-missing-action="1"{% endif %}
                    >
                        {% if csrf_token is defined %}
                            <input type="hidden" name="_token" value="{{ csrf_token }}" />
                        {% endif %}
                        <div class="angel-footer-store__newsletter-fields">
                            <input
                                type="email"
                                name="email"
                                class="angel-footer-store__newsletter-input"
                                placeholder="{{ settings.newsletter_placeholder | default(_('Enter email address'), true) }}"
                                autocomplete="email"
                                required
                            />
                            <button type="submit" class="angel-footer-store__newsletter-submit">
                                {{ settings.newsletter_button_text | default(_('Subscribe'), true) }}
                            </button>
                        </div>
                    </form>
                </div>
                <div class="angel-footer-store__social-top" aria-label="{{ _('Social media') }}">
                    {% if store.settings.contact.facebook %}
                        <a class="angel-footer-store__social-btn angel-footer-store__social-btn--facebook" href="https://www.facebook.com/{{ store.settings.contact.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
