                            </svg>
                        </a>
                    {% endif %}
                    {% if youtube_href %}
                        <a class="angel-footer-store__social-btn angel-footer-store__social-btn--youtube" href="{{ youtube_href }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32">
