{% if product.rating and product.rating.total_count > 0 %}
{% set total_reviews = product.rating.total_count %}
{% set count_5 = product.rating.ratings_5.count | default(0) %}
{% set count_4 = product.rating.ratings_4.count | default(0) %}
{% set count_3 = product.rating.ratings_3.count | default(0) %}
{% set count_2 = product.rating.ratings_2.count | default(0) %}
{% set count_1 = product.rating.ratings_1.count | default(0) %}
{% set recommend_pct = product.rating.recommendation_percentage | default(none) %}
{% if recommend_pct is none %}
    {% set recommend_count = count_5 + count_4 %}
    {% set recommend_pct = ((recommend_count * 100) / total_reviews) | round(0, 'floor') if total_reviews > 0 else 0 %}
{% endif %}

<section class="angel-reviews-summary" aria-label="{{ _('Reviews summary') }}">
    <div class="angel-reviews-summary__score">
        <p class="angel-reviews-summary__average">{{ product.rating.average }}</p>
        <div class="angel-reviews-summary__stars">
            {% set rating = product.rating.average %}{% set star_tone = 'cyan' %}{% include 'components/angel-rating-stars.jinja' %}
        </div>
        <p class="angel-reviews-summary__count">
            {% if total_reviews == 1 %}
                {{ _("Based on one rating") }}
            {% else %}
                {{ _("Based on %(count)s ratings") | format(count=total_reviews) }}
            {% endif %}
        </p>
        <div class="angel-reviews-summary__recommend">
            <span class="angel-reviews-summary__recommend-pct">{{ recommend_pct }}%</span>
            <span class="angel-reviews-summary__recommend-label">{{ _("Recommended the product") }}</span>
        </div>
    </div>

    <div class="angel-reviews-summary__bars">
        {% for star, count in [(5, count_5), (4, count_4), (3, count_3), (2, count_2), (1, count_1)] %}
            {% set bar_pct = ((count * 100) / total_reviews) | round(0, 'floor') if total_reviews > 0 else 0 %}
            <div class="angel-reviews-summary__bar-row">
                <span class="angel-reviews-summary__bar-pct">{{ bar_pct }}%</span>
                <div class="angel-reviews-summary__bar-track" role="presentation">
                    <span class="angel-reviews-summary__bar-fill" style="width: {{ bar_pct }}%;"></span>
                </div>
                <span class="angel-reviews-summary__bar-label">
                    <span class="angel-reviews-summary__bar-star" aria-hidden="true">★</span>
                    <span>{{ star }}</span>
                </span>
            </div>
        {% endfor %}
    </div>
</section>
{% endif %}
