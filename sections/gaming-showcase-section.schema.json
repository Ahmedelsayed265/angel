{
    "section_id": "angel-gaming-showcase-section",
    "template": "sections/gaming-showcase-section.jinja",
    "icon": "fa fa-gamepad",
    "name": {
        "ar": "بانر الألعاب",
        "en": "Gaming showcase"
    },
    "settings": [
        {
            "id": "home_tab",
            "type": "select",
            "label": {
                "ar": "اختر التبويب",
                "en": "Select tab"
            },
            "info": {
                "ar": "اتركه فارغًا ليظهر في كل التبويبات. أو اختر تبويبًا محددًا ليظهر داخله فقط.",
                "en": "Leave empty to show in all tabs. Or choose a specific tab to show only there."
            },
            "default": "",
            "options": [
                { "value": "", "label": { "ar": "كل التبويبات", "en": "All tabs" } },
                { "value": "1", "label": { "ar": "تبويب 1", "en": "Tab 1" } },
                { "value": "2", "label": { "ar": "تبويب 2", "en": "Tab 2" } },
                { "value": "3", "label": { "ar": "تبويب 3", "en": "Tab 3" } }
            ]
        },
        {
            "id": "bg_image",
            "type": "image",
            "label": {
                "ar": "صورة الخلفية",
                "en": "Background image"
            }
        },
        {
            "id": "section_bg",
            "type": "color",
            "label": {
                "ar": "لون الخلفية السفلية",
                "en": "Bottom fade color"
            },
            "default": "#1a1a1a"
        },
        {
            "id": "cards",
            "type": "list",
            "max_items": 6,
            "label": {
                "ar": "بطاقات الألعاب (حتى 6)",
                "en": "Game cards (up to 6)"
            },
            "settings": [
                {
                    "id": "image",
                    "type": "image",
                    "label": {
                        "ar": "صورة البطاقة",
                        "en": "Card image"
                    }
                },
                {
                    "id": "url",
                    "type": "url",
                    "label": {
                        "ar": "الرابط",
                        "en": "Link"
                    }
                }
            ]
        }
    ]
}
