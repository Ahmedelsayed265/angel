{
    "section_id": "angel-flip-banner-section",
    "template": "sections/flip-banner-section.jinja",
    "icon": "fa fa-clone",
    "name": {
        "ar": "بانر قلب 3D",
        "en": "3D flip banner"
    },
    "settings": [
        {
            "id": "home_tab",
            "type": "select",
            "label": {
                "ar": "اختر التبويب",
                "en": "Select tab"
            },
            "info": {
                "ar": "اتركه فارغًا ليظهر في كل التبويبات. أو اختر تبويبًا محددًا ليظهر داخله فقط.",
                "en": "Leave empty to show in all tabs. Or choose a specific tab to show only there."
            },
            "default": "",
            "options": [
                { "value": "", "label": { "ar": "كل التبويبات", "en": "All tabs" } },
                { "value": "1", "label": { "ar": "تبويب 1", "en": "Tab 1" } },
                { "value": "2", "label": { "ar": "تبويب 2", "en": "Tab 2" } },
                { "value": "3", "label": { "ar": "تبويب 3", "en": "Tab 3" } }
            ]
        },
        {
            "id": "image_front",
            "type": "image",
            "label": {
                "ar": "الصورة الأولى",
                "en": "Image 1"
            }
        },
        {
            "id": "url_front",
            "type": "url",
            "label": {
                "ar": "رابط الصورة الأولى (اختياري)",
                "en": "Image 1 link (optional)"
            }
        },
        {
            "id": "image_back",
            "type": "image",
            "label": {
                "ar": "الصورة الثانية",
                "en": "Image 2"
            }
        },
        {
            "id": "url_back",
            "type": "url",
            "label": {
                "ar": "رابط الصورة الثانية (اختياري)",
                "en": "Image 2 link (optional)"
            }
        },
        {
            "id": "flip_interval",
            "type": "number",
            "label": {
                "ar": "مدة الانتظار بين القلبات (ثانية)",
                "en": "Seconds between flips"
            },
            "default": 5,
            "min": 3,
            "max": 30
        },
        {
            "id": "flip_duration",
            "type": "select",
            "label": {
                "ar": "سرعة حركة القلب",
                "en": "Flip animation speed"
            },
            "options": [
                { "value": "600", "label": { "ar": "سريع", "en": "Fast" } },
                { "value": "800", "label": { "ar": "متوسط", "en": "Medium" } },
                { "value": "1000", "label": { "ar": "بطيء", "en": "Slow" } }
            ],
            "default": "800"
        },
        {
            "id": "pause_on_hover",
            "type": "checkbox",
            "label": {
                "ar": "إيقاف التبديل عند تمرير الماوس",
                "en": "Pause on hover"
            },
            "default": true
        },
        {
            "id": "drag_flip",
            "type": "checkbox",
            "label": {
                "ar": "القلب بالسحب (ماوس / لمس)",
                "en": "Flip by drag (mouse / touch)"
            },
            "info": {
                "ar": "اسحب يمينًا أو يسارًا لقلب البانر. يعمل مع التبديل التلقائي.",
                "en": "Drag left or right to flip. Works alongside auto-flip."
            },
            "default": true
        },
        {
            "id": "bg_color",
            "type": "color",
            "label": {
                "ar": "لون الخلفية",
                "en": "Background color"
            },
            "default": "#141414"
        },
        {
            "id": "border_radius",
            "type": "number",
            "label": {
                "ar": "انحناء الزوايا (px)",
                "en": "Border radius (px)"
            },
            "default": 12,
            "min": 0,
            "max": 32
        }
    ]
}
