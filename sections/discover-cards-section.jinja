{% set items = safeget(settings, "cards", []) %}
{% set section_title = settings.title | default("اكتشف") %}
{% set title_color = settings.title_color | default("#54c8e9") %}
{% set bg_color = settings.bg_color | default("#141414") %}
{% set card_bg = settings.card_bg_color | default("#2b2b2b") %}
{% set accent = settings.accent_color | default("#54c8e9") %}
{% set btn_bg = settings.button_bg_color | default("#54c8e9") %}
{% set btn_color = settings.button_text_color | default("#0f172a") %}
{% set slides_desktop = (settings.slides_desktop | default('3')) | int %}
{% set slides_count = slides_desktop if slides_desktop >= 2 and slides_desktop <= 4 else 3 %}

{% if section_title or items | length > 0 %}
<link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}">

<section
  id="{{ sectionId }}"
  section-id="{{ sectionId }}"
  class="angel-discover-cards"
  style="
    --adc-bg: {{ bg_color }};
    --adc-title: {{ title_color }};
    --adc-card-bg: {{ card_bg }};
    --adc-accent: {{ accent }};
    --adc-btn-bg: {{ btn_bg }};
    --adc-btn-color: {{ btn_color }};
    --adc-slides: {{ slides_count }};
  "
>
  <div class="container angel-discover-cards__inner">
    {% if section_title %}
      <header class="angel-discover-cards__header">
        <h2 class="angel-discover-cards__title">{{ section_title }}</h2>
      </header>
    {% endif %}

    {% if items | length > 0 %}
      <div class="angel-discover-cards__slider-wrap">
        <div class="swiper angel-discover-cards-swiper">
          <div class="swiper-wrapper">
            {% for item in items %}
              {% if item.image or item.title or item.description %}
                <div class="swiper-slide">
                  <article class="angel-discover-card">
                    {% if item.image %}
                      <div class="angel-discover-card__media">
                        <img
                          class="angel-discover-card__img"
                          src="{{ item.image }}"
                          alt="{{ item.title if item.title else '' }}"
                          loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
                        >
                      </div>
                    {% endif %}
                    <div class="angel-discover-card__body">
                      {% if item.title %}
                        <h3 class="angel-discover-card__title">{{ item.title }}</h3>
                      {% endif %}
                      {% if item.description %}
                        <p class="angel-discover-card__desc">{{ item.description }}</p>
                      {% endif %}
                      {% if item.button_text %}
                        <a
                          class="angel-discover-card__btn"
                          href="{{ item.url if item.url else 'javascript:;' }}"
                        >{{ item.button_text }}</a>
                      {% endif %}
                    </div>
                  </article>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        <div class="angel-discover-cards__scrollbar swiper-scrollbar" aria-hidden="true"></div>
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}"></script>
<script>
  (function () {
    var section = document.getElementById('{{ sectionId }}');
    if (!section) return;

    function initSwiper() {
      var el = section.querySelector('.angel-discover-cards-swiper');
      if (!el || el.classList.contains('swiper-initialized') || typeof Swiper === 'undefined') {
        return !!el && el.classList.contains('swiper-initialized');
      }

      var scrollbarEl = section.querySelector('.angel-discover-cards__scrollbar');
      var isRtl = window.appDirection === 'rtl';
      var slideGap = 16;

      function updateScrollbar(sw) {
        if (!scrollbarEl) return;
        scrollbarEl.style.display = sw.isLocked ? 'none' : '';
      }

      var swiper = new Swiper(el, {
        slidesPerView: 'auto',
        slidesPerGroup: 1,
        spaceBetween: slideGap,
        speed: 500,
        direction: 'horizontal',
        rtl: isRtl,
        watchOverflow: true,
        observer: true,
        observeParents: true,
        scrollbar: scrollbarEl ? {
          el: scrollbarEl,
          draggable: true,
          hide: false
        } : false,
        on: {
          init: function () { updateScrollbar(this); },
          resize: function () { updateScrollbar(this); },
          breakpoint: function () { updateScrollbar(this); }
        }
      });

      return true;
    }

    if (!initSwiper()) {
      window.addEventListener('load', initSwiper);
    }
  })();
</script>
{% endif %}
