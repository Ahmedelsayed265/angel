        {
            "id": "button_bg_color",
            "type": "color",
            "label": {
                "ar": "لون خلفية الزر",
                "en": "Button background"
            },
            "default": "#54c8e9"
        },
        {
            "id": "button_text_color",
            "type": "color",
            "label": {
                "ar": "لون نص الزر",
                "en": "Button text color"
            },
            "default": "#0f172a"
        }
