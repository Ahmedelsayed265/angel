{
    "section_id": "angel-promo-banner-section",
    "template": "sections/promo-banner-section.jinja",
    "icon": "fa fa-picture-o",
    "name": {
        "ar": "بانر ترويجي",
        "en": "Promo banner"
    },
    "settings": [
        {
            "id": "home_tab",
            "type": "select",
            "label": {
                "ar": "عرض داخل تبويب الرئيسية",
                "en": "Show in home tab"
            },
            "info": {
                "ar": "اتركه فارغًا ليظهر في كل التبويبات. أو اختر تبويبًا محددًا ليظهر داخله فقط.",
                "en": "Leave empty to show in all tabs. Or choose a specific tab to show only there."
            },
            "default": "",
            "options": [
                { "value": "", "label": { "ar": "كل التبويبات (افتراضي)", "en": "All tabs (default)" } },
                { "value": "1", "label": { "ar": "تبويب 1", "en": "Tab 1" } },
                { "value": "2", "label": { "ar": "تبويب 2", "en": "Tab 2" } },
                { "value": "3", "label": { "ar": "تبويب 3", "en": "Tab 3" } }
            ]
        },
        {
            "id": "image_desktop",
            "type": "image",
            "label": {
                "ar": "صورة سطح المكتب",
                "en": "Desktop image"
            },
            "info": {
                "ar": "بانر بعرض الشاشة كاملاً — يظهر تحت النص",
                "en": "Full-width banner shown below the text"
            }
        },
        {
            "id": "image_mobile",
            "type": "image",
            "label": {
                "ar": "صورة الجوال",
                "en": "Mobile image"
            },
            "info": {
                "ar": "إن تُركت فارغة تُستخدم صورة سطح المكتب",
                "en": "If empty, desktop image is used"
            }
        },
        {
            "id": "title",
            "type": "text",
            "label": {
                "ar": "العنوان",
                "en": "Title"
            },
            "default": "iPhone 15 Pro"
        },
        {
            "id": "subtitle",
            "type": "text",
            "label": {
                "ar": "الوصف",
                "en": "Subtitle"
            },
            "default": ""
        },
        {
            "id": "button_text",
            "type": "text",
            "label": {
                "ar": "نص الزر",
                "en": "Button text"
            },
            "default": "اعرف المزيد"
        },
        {
            "id": "button_url",
            "type": "url",
            "label": {
                "ar": "رابط الزر",
                "en": "Button URL"
            }
        },
        {
            "id": "bg_color",
            "type": "color",
            "label": {
                "ar": "لون الخلفية",
                "en": "Background color"
            },
            "default": "#000000"
        },
        {
            "id": "title_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان",
                "en": "Title color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "subtitle_color",
            "type": "color",
            "label": {
                "ar": "لون الوصف",
                "en": "Subtitle color"
            },
            "default": "#ffffff"
        },
        {
            "id": "button_bg_color",
            "type": "color",
            "label": {
                "ar": "لون خلفية الزر",
                "en": "Button background"
            },
            "default": "#54c8e9"
        },
        {
            "id": "button_text_color",
            "type": "color",
            "label": {
                "ar": "لون نص الزر",
                "en": "Button text color"
            },
            "default": "#0f172a"
        }
    ]
}
