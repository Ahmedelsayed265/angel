{
    "section_id": "angel-promo-banner-section",
    "template": "sections/promo-banner-section.jinja",
    "icon": "fa fa-picture-o",
    "name": {
        "ar": "بانر ترويجي",
        "en": "Promo banner"
    },
    "settings": [
        {
            "id": "image_desktop",
            "type": "image",
            "label": {
                "ar": "صورة سطح المكتب",
                "en": "Desktop image"
            },
            "info": {
                "ar": "بانر بعرض الشاشة كاملاً — يظهر تحت النص",
                "en": "Full-width banner shown below the text"
            }
        },
        {
            "id": "image_mobile",
            "type": "image",
            "label": {
                "ar": "صورة الجوال",
                "en": "Mobile image"
            },
            "info": {
                "ar": "إن تُركت فارغة تُستخدم صورة سطح المكتب",
                "en": "If empty, desktop image is used"
            }
        },
        {
            "id": "title",
            "type": "text",
            "label": {
                "ar": "العنوان",
                "en": "Title"
            },
            "default": "iPhone 15 Pro"
        },
        {
            "id": "subtitle",
            "type": "text",
            "label": {
                "ar": "الوصف",
                "en": "Subtitle"
            },
            "default": ""
        },
        {
            "id": "button_text",
            "type": "text",
            "label": {
                "ar": "نص الزر",
                "en": "Button text"
            },
            "default": "اعرف المزيد"
        },
        {
            "id": "button_url",
            "type": "url",
            "label": {
                "ar": "رابط الزر",
                "en": "Button URL"
            }
        },
        {
            "id": "bg_color",
            "type": "color",
            "label": {
                "ar": "لون الخلفية",
                "en": "Background color"
            },
            "default": "#000000"
        },
        {
            "id": "title_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان",
                "en": "Title color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "subtitle_color",
            "type": "color",
            "label": {
                "ar": "لون الوصف",
                "en": "Subtitle color"
            },
            "default": "#ffffff"
