{
    "section_id": "angel-faq-section",
    "template": "sections/faq-section.jinja",
    "icon": "fa fa-question-circle",
    "name": {
        "ar": "الأسئلة الشائعة",
        "en": "FAQ"
    },
    "settings": [
        {
            "id": "title",
            "type": "text",
            "label": {
                "ar": "العنوان",
                "en": "Title"
            },
            "default": "الأسئلة الشائعة"
        },
        {
            "id": "subtitle",
            "type": "text",
            "label": {
                "ar": "العنوان الفرعي",
                "en": "Subtitle"
            },
            "default": "إجابات على أهم الأسئلة"
        },
        {
            "id": "title_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان",
                "en": "Title color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "bg_color",
            "type": "color",
            "label": {
                "ar": "لون الخلفية",
                "en": "Background color"
            },
            "default": "#141414"
        },
        {
            "id": "card_bg_color",
            "type": "color",
            "label": {
                "ar": "لون البطاقة",
                "en": "Card background"
            },
            "default": "#2b2b2b"
        },
        {
            "id": "accent_color",
            "type": "color",
            "label": {
                "ar": "لون التمييز (نشط)",
                "en": "Accent color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "open_first",
            "type": "checkbox",
            "label": {
                "ar": "فتح أول سؤال افتراضياً",
                "en": "Open first item by default"
            },
            "default": false
        },
        {
            "id": "faq_items",
            "type": "list",
            "max_items": 12,
            "label": {
                "ar": "الأسئلة والأجوبة",
                "en": "FAQ items"
            },
            "settings": [
                {
                    "id": "question",
                    "type": "text",
                    "label": {
                        "ar": "السؤال",
                        "en": "Question"
                    }
                },
                {
                    "id": "answer",
                    "type": "textarea",
                    "label": {
                        "ar": "الإجابة",
                        "en": "Answer"
                    }
                },
                {
                    "id": "button_text",
                    "type": "text",
                    "label": {
                        "ar": "نص الزر",
                        "en": "Button text"
                    },
                    "default": "اعرف أكثر"
                },
                {
                    "id": "button_url",
                    "type": "url",
                    "label": {
                        "ar": "رابط الزر",
                        "en": "Button URL"
                    }
                }
            ]
        }
    ]
}
