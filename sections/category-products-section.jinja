{% set products = safeget(settings, "category.products.results", []) %}
{% set display_title = settings.title | default(safeget(settings, "category.name", "")) %}
{% set subtitle = settings.subtitle | default("") %}
{% set bg_image = settings.bg_image | default(safeget(settings, "category.cover_image", "")) %}
{% set overlay = settings.overlay_opacity | default(65) %}
{% set title_color = settings.title_color | default("#ffffff") %}
{% set subtitle_color = settings.subtitle_color | default("#ffffff") %}
{% set accent = settings.accent_color | default("#54c8e9") %}
{% set slides_desktop = (settings.slides_desktop | default('6')) | int %}
{% set show_arrows = settings.show_arrows | default(true) %}
{% set bg_height = settings.bg_height | default(384) %}
{% set slides_count = slides_desktop if slides_desktop >= 2 and slides_desktop <= 8 else 6 %}

{% if products and products | length > 0 %}
<link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}">

<section
  id="{{ sectionId }}"
  section-id="{{ sectionId }}"
  class="angel-category-products"
  data-slides-desktop="{{ slides_count }}"
  data-product-count="{{ products | length }}"
  style="
    --cp-title: {{ title_color }};
    --cp-subtitle: {{ subtitle_color }};
    --cp-accent: {{ accent }};
    --cp-overlay: {{ overlay }}%;
    --cp-slides: {{ slides_count }};
    --cp-bg-height: {{ bg_height }}px;
  "
>
  <div class="angel-category-products__banner">
    {% if bg_image %}
      <div class="angel-category-products__bg" aria-hidden="true">
        <img class="angel-category-products__bg-img" src="{{ bg_image }}" alt="" loading="lazy">
      </div>
    {% else %}
      <span class="angel-category-products__bg angel-category-products__bg--fallback" aria-hidden="true"></span>
    {% endif %}
    <span class="angel-category-products__overlay" aria-hidden="true"></span>

    <div class="container angel-category-products__toolbar-wrap">
      <div class="angel-category-products__toolbar">
        {% if display_title or subtitle %}
          <header class="angel-category-products__header">
            {% if display_title %}
              <h2 class="angel-category-products__title">{{ display_title }}</h2>
            {% endif %}
            {% if subtitle %}
              <p class="angel-category-products__subtitle">{{ subtitle }}</p>
            {% endif %}
          </header>
        {% endif %}
        {% if show_arrows %}
          <div class="angel-category-products__nav-wrap">
            <button type="button" class="swiper-button-prev angel-category-products__nav angel-category-products__nav--prev" aria-label="{{ _('Previous') }}"></button>
            <button type="button" class="swiper-button-next angel-category-products__nav angel-category-products__nav--next" aria-label="{{ _('Next') }}"></button>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="angel-category-products__products">
    <div class="container">
      <div class="swiper angel-category-products-swiper">
        <div class="swiper-wrapper">
          {% for product in products %}
            <div class="swiper-slide">
              {% include 'components/angel-category-product-card.jinja' %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}"></script>
<script>
  (function () {
    var section = document.getElementById('{{ sectionId }}');
    if (!section) return;

    var root = section.closest('[section-id]') || section.parentElement || section;
    root.querySelectorAll(
      '.category-products-display-more-section, .angel-category-products__more-wrap, a.more-button.btn-outline-primary'
    ).forEach(function (el) {
      el.remove();
    });

    function initSwiper() {
      var el = section.querySelector('.angel-category-products-swiper');
      if (!el || el.classList.contains('swiper-initialized') || typeof Swiper === 'undefined') {
        return !!el && el.classList.contains('swiper-initialized');
      }

      var isRtl = window.appDirection === 'rtl';
      var showArrows = {{ 'true' if show_arrows else 'false' }};

      new Swiper(el, {
        slidesPerView: 'auto',
        slidesPerGroup: 1,
        spaceBetween: 0,
        speed: 500,
        direction: 'horizontal',
        rtl: isRtl,
        watchOverflow: true,
        observer: true,
        observeParents: true,
        navigation: showArrows ? {
          nextEl: section.querySelector('.angel-category-products__nav--next'),
          prevEl: section.querySelector('.angel-category-products__nav--prev')
        } : false
      });

      return true;
    }

    if (!initSwiper()) {
      window.addEventListener('load', initSwiper);
    }
  })();
</script>
{% endif %}
