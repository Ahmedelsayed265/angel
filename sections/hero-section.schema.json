{
    "section_id": "uuid",
    "template": "sections/hero-section.jinja",
    "icon": "fa fa-image",
    "name": {
        "ar": "القسم الرئيسي",
        "en": "Hero section"
    },
    "settings": [
        {
            "id": "home_title",
            "type": "text",
            "label": {
                "ar": "الرئيسية — عنوان التبويب",
                "en": "Home — tab title"
            },
            "default": "الرئيسية"
        },
        {
            "id": "home_accent_color",
            "type": "color",
            "label": {
                "ar": "الرئيسية — لون خط التبويب",
                "en": "Home — tab accent"
            },
            "default": "#54c8e9"
        },
        {
            "id": "home_video",
            "type": "video",
            "label": {
                "ar": "الرئيسية — فيديو أعلى الصفحة",
                "en": "Home — top video"
            }
        },
        {
            "id": "home_display_video",
            "type": "checkbox",
            "label": {
                "ar": "الرئيسية — عرض الفيديو",
                "en": "Home — show video"
            },
            "default": true
        },
        {
            "id": "home_video_loop",
            "type": "checkbox",
            "label": {
                "ar": "الرئيسية — تكرار الفيديو (Loop)",
                "en": "Home — video loop"
            },
            "default": true
        },
        {
            "id": "home_video_url",
            "type": "url",
            "label": {
                "ar": "الرئيسية — رابط عند الضغط على الفيديو",
                "en": "Home — video click URL"
            },
            "info": {
                "ar": "عند الضغط على الفيديو ينتقل الزائر لهذا الرابط",
                "en": "Visitors go to this URL when clicking the video"
            }
        },
        {
            "id": "home_bg_image",
            "type": "image",
            "label": {
                "ar": "الرئيسية — غلاف الفيديو / صورة بديلة",
                "en": "Home — video poster"
            }
        },
        {
            "id": "home_heading",
            "type": "text",
            "label": {
                "ar": "الرئيسية — العنوان فوق الفيديو",
                "en": "Home — heading overlay"
            },
            "default": "مع ملاك"
        },
        {
            "id": "home_heading_color",
            "type": "color",
            "label": {
                "ar": "الرئيسية — لون العنوان",
                "en": "Home — heading color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "home_cards",
            "type": "list",
            "max_items": 6,
            "label": {
                "ar": "الرئيسية — البطاقات (حد أقصى 6)",
                "en": "Home — cards (max 6)"
            },
            "info": {
                "ar": "أضف حتى 6 بطاقات: صورة كاملة للبطاقة ورابط.",
                "en": "Add up to 6 cards: full card image and link."
            },
            "settings": [
                {
                    "id": "title",
                    "type": "text",
                    "label": {
                        "ar": "عنوان التبويب",
                        "en": "Tab title"
                    }
                },
                {
                    "id": "image",
                    "type": "image",
                    "label": {
                        "ar": "الصورة",
                        "en": "Image"
                    }
                },
                {
                    "id": "video",
                    "type": "video",
                    "label": {
                        "ar": "الفيديو",
                        "en": "Video"
                    }
                },
                {
                    "id": "display_video",
                    "type": "checkbox",
                    "label": {
                        "ar": "عرض الفيديو",
                        "en": "Display video"
                    },
                    "info": {
                        "ar": "عند التفعيل، يتم عرض الفيديو بدلاً من الصورة لهذا التبويب.",
                        "en": "When enabled, the video is shown instead of the image for this tab."
                    },
                    "default": false
                }
            ]
        }
