        { "id": "title", "type": "text", "label": { "ar": "العنوان", "en": "Title" } },
        { "id": "url", "type": "url", "label": { "ar": "الرابط", "en": "URL" } },
        { "id": "button_text", "type": "text", "label": { "ar": "نص الزر", "en": "Button text" } }
