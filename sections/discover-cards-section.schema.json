{
  "section_id": "angel-discover-cards-section",
  "template": "sections/discover-cards-section.jinja",
  "icon": "fa fa-newspaper-o",
  "name": {
    "ar": "مقالات متحركة (ملاك)",
    "en": "Moving articles (Angel)"
  },
  "settings": [
        {
            "id": "home_tab",
            "type": "select",
            "label": {
                "ar": "اختر التبويب",
                "en": "Select tab"
            },
            "info": {
                "ar": "اتركه فارغًا ليظهر في كل التبويبات. أو اختر تبويبًا محددًا ليظهر داخله فقط.",
                "en": "Leave empty to show in all tabs. Or choose a specific tab to show only there."
            },
            "default": "",
            "options": [
                { "value": "", "label": { "ar": "كل التبويبات", "en": "All tabs" } },
                { "value": "1", "label": { "ar": "تبويب 1", "en": "Tab 1" } },
                { "value": "2", "label": { "ar": "تبويب 2", "en": "Tab 2" } },
                { "value": "3", "label": { "ar": "تبويب 3", "en": "Tab 3" } }
            ]
        },
    {
      "id": "title",
      "type": "text",
      "label": {
        "ar": "العنوان",
        "en": "Title"
      },
      "default": "مقالات متحركة"
    },
    {
      "id": "title_p",
      "type": "text",
      "label": {
        "ar": "عنوان فرعي",
        "en": "Subtitle"
      },
      "default": "اطلع على أحدث الأخبار"
    },
    {
      "id": "dark",
      "type": "checkbox",
      "label": {
        "ar": "تثبيت المظهر الداكن",
        "en": "Pin dark appearance"
      },
      "default": false
    },
    {
      "id": "items",
      "type": "list",
      "max_items": 12,
      "label": {
        "ar": "المقالات",
        "en": "Articles"
      },
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": {
            "ar": "صور المقال",
            "en": "Article image"
          }
        },
        {
          "id": "title",
          "type": "text",
          "label": {
            "ar": "عنوان المقال",
            "en": "Article title"
          }
        },
        {
          "id": "text",
          "type": "textarea",
          "label": {
            "ar": "ملخص المقال",
            "en": "Article summary"
          }
        },
        {
          "id": "btn",
          "type": "text",
          "label": {
            "ar": "نص الزر",
            "en": "Button text"
          },
          "default": "قراءة المزيد"
        },
        {
          "id": "url",
          "type": "url",
          "label": {
            "ar": "رابط الزر",
            "en": "Button link"
          }
        }
      ]
    },
    {
      "id": "block_bg",
      "type": "color",
      "label": {
        "ar": "لون خلفية العنصر",
        "en": "Element background color"
      },
      "info": {
        "ar": "استخدم الأبيض (#ffffff) للحصول على خلفية شفافة.",
        "en": "Use white (#ffffff) for a transparent background."
      },
      "default": "#141414"
    },
    {
      "id": "block_img",
      "type": "image",
      "label": {
        "ar": "صورة خلفية العنصر",
        "en": "Element background image"
      }
    },
    {
      "id": "mobile_only",
      "type": "checkbox",
      "label": {
        "ar": "عرض العنصر في الجوال فقط",
        "en": "Show on mobile only"
      },
      "default": false
    },
    {
      "id": "pc_only",
      "type": "checkbox",
      "label": {
        "ar": "عرض العنصر في الكمبيوتر والتابلت فقط",
        "en": "Show on desktop/tablet only"
      },
      "default": false
    },
    {
      "id": "ar_only",
      "type": "checkbox",
      "label": {
        "ar": "عرض العنصر في الواجهة باللغة العربية فقط",
        "en": "Arabic interface only"
      },
      "default": false
    },
    {
      "id": "en_only",
      "type": "checkbox",
      "label": {
        "ar": "عرض العنصر في الواجهة بالإنجليزية فقط",
        "en": "English interface only"
      },
      "default": false
    },
    {
      "id": "wow",
      "type": "select",
      "label": {
        "ar": "أنيميشن ملاك",
        "en": "Angel animation"
      },
      "default": "false",
      "options": [
        { "value": "false", "label": { "ar": "إيقاف", "en": "Off" } },
        { "value": "fade-in", "label": { "ar": "ظهور", "en": "Fade in" } },
        { "value": "fade-up", "label": { "ar": "ظهور لأعلى", "en": "Fade up" } },
        { "value": "fade-down", "label": { "ar": "ظهور لأسفل", "en": "Fade down" } },
        { "value": "blur-in", "label": { "ar": "وضوح", "en": "Blur in" } },
        { "value": "scale-in", "label": { "ar": "تكبير", "en": "Scale in" } },
        { "value": "bounce-in", "label": { "ar": "قفز لأعلى", "en": "Bounce in" } },
        { "value": "flip-y", "label": { "ar": "دوران عمودي", "en": "Flip Y" } }
      ]
    },
    {
      "id": "classes",
      "type": "text",
      "label": {
        "ar": "Classes",
        "en": "Classes"
      },
      "info": {
        "ar": "أضف كلاسات خاصة لحاوية السيكشن.",
        "en": "Add special classes to the parent section."
      }
    }
  ]
}
