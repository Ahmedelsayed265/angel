{% set cards = safeget(settings, "cards", []) %}
{% set section_bg = settings.section_bg | default("#1a1a1a") %}
{% set home_tab = settings.home_tab | default('') %}

{% if settings.bg_image or cards | length > 0 %}
<section
  id="{{ sectionId }}"
  section-id="{{ sectionId }}"
  class="angel-gaming-showcase"
  {% if home_tab in ['1', '2', '3'] %}data-home-tab="{{ home_tab }}"{% endif %}
  style="--ags-section-bg: {{ section_bg }};"
>
  <div class="angel-gaming-showcase__stage">
    {% if settings.bg_image %}
      <div class="angel-gaming-showcase__media">
        <img
          class="angel-gaming-showcase__img"
          src="{{ settings.bg_image }}"
          alt=""
          loading="eager"
        >
        <span class="angel-gaming-showcase__fade" aria-hidden="true"></span>
      </div>
    {% endif %}

    {% if cards | length > 0 %}
      <div class="container angel-gaming-showcase__cards-outer">
        <div class="angel-gaming-showcase__cards">
          {% for card in cards %}
            {% if card.image %}
              <a
                class="angel-gaming-showcase__card"
                href="{{ card.url if card.url else 'javascript:;' }}"
              >
                <img
                  class="angel-gaming-showcase__card-img"
                  src="{{ card.image }}"
                  alt=""
                  loading="{% if loop.index <= 3 %}eager{% else %}lazy{% endif %}"
                >
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>
{% endif %}
