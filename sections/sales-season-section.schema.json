        },
        {
            "id": "more_url",
            "type": "url",
            "label": {
                "ar": "رابط تصفح المزيد",
                "en": "Browse more URL"
            }
        },
        {
            "id": "title_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان",
                "en": "Title color"
            },
            "default": "#54c8e9"
        },
        {
            "id": "subtitle_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان الفرعي",
                "en": "Subtitle color"
