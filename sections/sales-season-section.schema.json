        },
        {
            "id": "title",
            "type": "text",
            "label": {
                "ar": "العنوان",
                "en": "Title"
            },
            "default": "لايفوتك موسم التخفيضات"
        },
        {
            "id": "subtitle",
            "type": "text",
            "label": {
                "ar": "العنوان الفرعي",
