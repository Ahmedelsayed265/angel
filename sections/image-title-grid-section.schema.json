{
    "section_id": "angel-image-title-grid-section",
    "template": "sections/image-title-grid-section.jinja",
    "icon": "fa fa-th",
    "name": {
        "ar": "شبكة صورة وعنوان",
        "en": "Image & title grid"
    },
    "settings": [
        {
            "id": "home_tab",
            "type": "select",
            "label": {
                "ar": "اختر التبويب",
                "en": "Select tab"
            },
            "info": {
                "ar": "اتركه فارغًا ليظهر في كل التبويبات. أو اختر تبويبًا محددًا ليظهر داخله فقط.",
                "en": "Leave empty to show in all tabs. Or choose a specific tab to show only there."
            },
            "default": "",
            "options": [
                { "value": "", "label": { "ar": "كل التبويبات", "en": "All tabs" } },
                { "value": "1", "label": { "ar": "تبويب 1", "en": "Tab 1" } },
                { "value": "2", "label": { "ar": "تبويب 2", "en": "Tab 2" } },
                { "value": "3", "label": { "ar": "تبويب 3", "en": "Tab 3" } }
            ]
        },
        {
            "id": "bg_color",
            "type": "color",
            "label": {
                "ar": "لون الخلفية",
                "en": "Background color"
            },
            "default": "#141414"
        },
        {
            "id": "item_title_color",
            "type": "color",
            "label": {
                "ar": "لون العنوان",
                "en": "Title color"
            },
            "default": "#ffffff"
        },
        {
            "id": "columns",
            "type": "select",
            "label": {
                "ar": "عدد الأعمدة (سطح المكتب)",
                "en": "Columns (desktop)"
            },
            "default": "3",
            "options": [
                {
                    "value": "2",
                    "label": {
                        "ar": "2",
                        "en": "2"
                    }
                },
                {
                    "value": "3",
                    "label": {
                        "ar": "3",
                        "en": "3"
                    }
                },
                {
                    "value": "4",
                    "label": {
                        "ar": "4",
                        "en": "4"
                    }
                }
            ]
        },
        {
            "id": "items",
            "type": "list",
            "max_items": 12,
            "label": {
                "ar": "العناصر",
                "en": "Items"
            },
            "settings": [
                {
                    "id": "image",
                    "type": "image",
                    "label": {
                        "ar": "الصورة",
                        "en": "Image"
                    }
                },
                {
                    "id": "title",
                    "type": "text",
                    "label": {
                        "ar": "العنوان",
                        "en": "Title"
                    }
                }
            ]
        }
    ]
}
