{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}"/>
    <link rel="stylesheet" type="text/css" href="{{ 'swiper-bundle.min.css' | asset_url }}"/>
    <link rel="stylesheet" type="text/css" href="{{ ('angel-category.css?v=0.1.051') | asset_url }}"/>
{% endblock %}

{% block main_content %}

{% set category_page_hide_main_products = settings.category_page_hide_main_products | default(false) %}
{% set category_page_mobile_cols = settings.category_page_mobile_columns_when_hidden | default('2') %}
{% set category_page_desktop_cols = settings.category_page_desktop_columns_when_hidden | default('6') %}
{% set category_page_slider = settings.category_page_show_subcategories_as_slider | default(false) %}
{% set category_page_load_same_page = settings.category_page_load_subcategory_products_same_page | default(false) %}
{% set category_page_square_banners = settings.category_page_banners_square | default(false) %}
{% set category_page_separate_banners = settings.category_page_banners_separate | default(false) %}

{% set raw_children = safeget(category, 'children_categories', safeget(category, 'children', safeget(category, 'sub_categories', safeget(category, 'subcategories', [])))) %}
{% set subcategories =
    raw_children
    if raw_children is iterable and raw_children is not boolean and raw_children is not string
    else []
%}
{% set hide_main_products_now = category_page_hide_main_products and (subcategories | length > 0) %}

{% set category_media_raw = safeget(settings, 'category_page_category_media', []) %}
{% set category_media =
    category_media_raw
    if category_media_raw is iterable and category_media_raw is not boolean and category_media_raw is not string
    else []
%}

{% set banners_raw = safeget(settings, 'category_page_banners', []) %}
{% set banners =
    banners_raw
    if banners_raw is iterable and banners_raw is not boolean and banners_raw is not string
    else []
%}

<div
    class="angel-category-page{% if hide_main_products_now %} angel-category-page--hide-products{% endif %}{% if category_page_slider %} angel-category-page--subcats-slider{% endif %}{% if category_page_square_banners %} angel-category-page--square-banners{% endif %}{% if category_page_separate_banners %} angel-category-page--separate-banners{% endif %}"
    data-angel-category-page
    data-hide-main-products="{{ 'true' if hide_main_products_now else 'false' }}"
    data-subcategory-load="{{ 'true' if category_page_load_same_page else 'false' }}"
    style="--angel-subcats-cols-mobile: {{ category_page_mobile_cols }}; --angel-subcats-cols-desktop: {{ category_page_desktop_cols }};"
>
    {% include 'components/angel-category-hero.jinja' %}

    <div class="container">
        {% set shown_banner_count = 0 %}
        {% for banner in banners %}
            {% set banner_cat = safeget(banner, 'category', none) %}
            {% if banner.image and banner_cat and (safeget(banner_cat, 'id', '') == safeget(category, 'id', '')) %}
                {% set shown_banner_count = shown_banner_count + 1 %}
            {% endif %}
        {% endfor %}

        {% if shown_banner_count > 0 %}
            <section class="angel-category-banners" aria-label="{{ _('Banners') }}">
                <div class="angel-category-banners__grid">
                    {% for banner in banners %}
                        {% set banner_cat = safeget(banner, 'category', none) %}
                        {% if banner.image and banner_cat and (safeget(banner_cat, 'id', '') == safeget(category, 'id', '')) %}
                            {% if banner.url %}
                                <a class="angel-category-banner" href="{{ banner.url }}">
                                    <img class="angel-category-banner__img" src="{{ image_url(banner.image, q=85) }}" alt="" loading="lazy" decoding="async">
                                </a>
                            {% else %}
                                <div class="angel-category-banner" aria-hidden="true">
                                    <img class="angel-category-banner__img" src="{{ image_url(banner.image, q=85) }}" alt="" loading="lazy" decoding="async">
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <div class="angel-category-page__layout">
            {% if products.filters | length > 0 %}
                <aside class="angel-category-page__sidebar" data-angel-filter-drawer aria-label="{{ _('Filter') }}">
                    <div class="angel-category-page__sidebar-head d-lg-none">
                        <span class="angel-category-page__sidebar-title">{{ _("Filter") }}</span>
                        <button type="button" class="angel-category-page__sidebar-close" data-angel-category-filter-close aria-label="{{ _('Close') }}">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="angel-side-filters-panel__inner">
                        <div id="angel-category-filters" class="angel-category-filters angel-side-filters">
                            {% set async = true %}
                            {% include 'vitrin:products/filters.jinja' %}
                        </div>
                        <button type="button" class="angel-category-filters__clear" data-angel-category-clear>
                            {{ _("Clear filter") }}
                        </button>
                    </div>
                </aside>
                <div class="angel-category-page__sidebar-backdrop d-lg-none" data-angel-category-filter-close hidden></div>
            {% endif %}

            <div class="angel-category-page__main">
                {% set count = products.count %}
                {% set has_products_filtration = (products.filters | length > 0) %}
                {% if not hide_main_products_now %}
                    {% include 'components/angel-category-toolbar.jinja' %}
                {% endif %}

                {% if hide_main_products_now %}
                    <section class="angel-category-subcats" aria-label="{{ _('Categories') }}">
                        <div class="angel-category-subcats__grid">
                            {% for subcat in subcategories %}
                                {% set custom = none %}
                                {% for cm in category_media %}
                                    {% set cm_cat = safeget(cm, 'category', none) %}
                                    {% if cm_cat and (safeget(cm_cat, 'id', '') == safeget(subcat, 'id', '')) %}
                                        {% set custom = cm %}
                                    {% endif %}
                                {% endfor %}

                                {% set sub_url = safeget(subcat, 'url', safeget(subcat, 'html_url', '')) %}
                                {% set sub_name = safeget(subcat, 'name', '') %}
                                {% set sub_img = safeget(custom, 'image', safeget(subcat, 'cover_image', safeget(subcat, 'image', ''))) %}
                                {% set sub_desc = safeget(custom, 'short_desc', '') %}
                                {% set sub_promo = safeget(custom, 'promo_title', '') %}

                                <a
                                    class="angel-category-subcat"
                                    href="{{ sub_url if sub_url else 'javascript:;' }}"
                                    {% if category_page_load_same_page and sub_url %}data-angel-subcategory-load data-subcategory-url="{{ sub_url }}"{% endif %}
                                >
                                    <span class="angel-category-subcat__media" aria-hidden="true">
                                        {% if sub_img %}
                                            <img class="angel-category-subcat__img" src="{{ image_url(sub_img, w=560, h=560, q=85, f='auto') }}" alt="" loading="lazy" decoding="async">
                                        {% else %}
                                            <span class="angel-category-subcat__img angel-category-subcat__img--placeholder"></span>
                                        {% endif %}
                                    </span>
                                    <span class="angel-category-subcat__body">
                                        {% if sub_desc %}<span class="angel-category-subcat__desc">{{ sub_desc }}</span>{% endif %}
                                        {% if sub_promo %}<span class="angel-category-subcat__promo">{{ sub_promo }}</span>{% endif %}
                                        <span class="angel-category-subcat__title">{{ sub_name }}</span>
                                    </span>
                                </a>
                            {% endfor %}
                        </div>
                    </section>

                    <section class="angel-category-subcat-products" id="angel-subcategory-products" hidden>
                        <div class="angel-category-subcat-products__head">
                            <h2 class="angel-category-subcat-products__title" id="angel-subcategory-products-title"></h2>
                            <button type="button" class="angel-category-subcat-products__back" data-angel-subcategory-back>
                                {{ _("Back") }}
                            </button>
                        </div>
                        <div class="angel-category-subcat-products__body">
                            <div id="products-list" class="angel-category-page__grid products-list"></div>
                            <div class="angel-category-page__pagination-wrap"></div>
                        </div>
                    </section>
                {% else %}
                    <div id="products-list" class="angel-category-page__grid products-list">
                        {% for product in products.results %}
                            {% set product = product %}
                            {% set index = key %}
                            {% include 'components/product-card.jinja' %}
                        {% endfor %}
                    </div>

                    {% if products.results | length == 0 %}
                        <p class="angel-category-page__empty">{{ _("No products") }}</p>
                    {% endif %}

                    <div class="angel-category-page__pagination-wrap">
                        {% set totalPages = products.pages_count %}
                        {% set currentPage = products.page %}
                        {% include 'components/pagination.jinja' %}
                    </div>
                {% endif %}

            </div>
        </div>
        {% include 'components/angel-category-testimonial.jinja' %}
    </div>

    {% if category.metafields %}
        <div class="angel-category-page__container angel-category-page__metafields">
            {% set entity = category %}
            {% include 'vitrin:shared/metafields.jinja' %}
        </div>
    {% endif %}
</div>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}

{% block footer_scripts %}
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ ('angel-side-filters.js?v=0.1.5') | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ ('angel-category.js?v=0.1.049') | asset_url }}" defer></script>
    <script>
        window.angelProductCardLabels = {
            chooseOptions: {{ _("Please choose product options first") | tojson }}
        };
        window.onProductAttributesTriggered = function () {
            var list = document.getElementById('products-list');
            var pagination = document.getElementById('product-pagination');
            if (list) {
                list.style.opacity = '0.4';
            }
            if (pagination) {
                pagination.style.opacity = '0';
            }
        };

        window.onProductAttributesChanged = function (htmlStr) {
            var html = $.parseHTML(htmlStr);
            var $html = $(html);
            var list = document.getElementById('products-list');
            var nextList = $html.find('#products-list').html();

            if (list && nextList) {
                list.innerHTML = nextList;
                list.style.opacity = '1';
            }

            var pagination = document.getElementById('product-pagination');
            var nextPagination = $html.find('#product-pagination').html();
            if (pagination && nextPagination) {
                pagination.innerHTML = nextPagination;
                pagination.style.opacity = '1';
            } else if (pagination) {
                pagination.style.opacity = '1';
            }

            if (window.AngelProductCard && window.AngelProductCard.init) {
                window.AngelProductCard.init(list || document);
            }
            if (window.AngelProductPage && window.AngelProductPage.bindGroupedQuickViewTriggers) {
                window.AngelProductPage.bindGroupedQuickViewTriggers(list || document);
            }
            if (window.bundleOffersLoader) {
                window.bundleOffersLoader.reload();
            }
            if (window.AngelCategoryPage && window.AngelCategoryPage.onProductsUpdated) {
                window.AngelCategoryPage.onProductsUpdated();
            }
        };
    </script>
{% endblock %}
