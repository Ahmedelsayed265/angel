{% block footer_scripts %}

    <script type="text/javascript" src="{{ 'ekko-lightbox.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ 'product-details.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ ('angel-product.js?v=' ~ ver) | asset_url }}" defer></script>
    <script>
        var productImages = {{ product.selected_product.media | tojson }};
        var customerWishlistIds = {{ customer.wishlist | tojson if customer else '[]' }};
        window.angelQuestionSuccessMessage = {{ _("Your question has been sent successfully. You will receive a notification if it is answered.") | tojson }};
        window.angelGroupedQvAddedMessage = {{ _("Added to cart successfully") | tojson }};


        $(window).on('load', function () {
            if (window.checkout_dialog) {
                $('.btn-buy-now').removeClass('d-none');
            }
        });

        window.zidProductBuyNow = async () => {
            if (typeof $ !== 'undefined') {
                var mainBuyLoader = $('.buy-now-progress');
                var stickyBuyLoader = $('.angel-product-sticky__buy-progress');
                var urgencyBuyLoader = $('.angel-product-urgency__buy-progress');
                if ((mainBuyLoader.length && !mainBuyLoader.hasClass('d-none')) ||
                    (stickyBuyLoader.length && !stickyBuyLoader.hasClass('d-none')) ||
                    (urgencyBuyLoader.length && !urgencyBuyLoader.hasClass('d-none'))) {
                    return;
                }
            }

            const buyNowLoading = (isLoading) => {
                $('.btn-buy-now').prop('disabled', isLoading);
                $('.buy-now-progress').toggleClass('d-none', !isLoading);
                $('.buy-now-icon').toggleClass('d-none', isLoading);
                $('.angel-product-sticky__buy').prop('disabled', isLoading);
                $('.angel-product-sticky__buy-progress').toggleClass('d-none', !isLoading);
                $('.angel-product-sticky__buy-content').toggleClass('d-none', isLoading);
                $('.angel-product-urgency__buy').prop('disabled', isLoading);
                $('.angel-product-urgency__buy-progress').toggleClass('d-none', !isLoading);
                $('.angel-product-urgency__buy > span').toggleClass('d-none', isLoading);
            };

            if (!window.zid?.cart?.buyNow) {
                window.zid?.toaster?.showError('{{ _("Cart service not available") }}');
                return;
            }

            const bundlePayload = window.bundleCartPayload;
            const addProductOptions = bundlePayload
                ? { ...bundlePayload, form_id: 'product-form' }
                : { form_id: 'product-form' };

            try {
                buyNowLoading(true);
                await window.zid.cart.buyNow(addProductOptions, { showErrorNotification: true });
            } catch (error) {
                console.error(error, 'Buy Now failed');
            } finally {
                buyNowLoading(false);
            }
        }

        // Listen for bundle selection changes and update payload
        window.addEventListener('vitrin:bundle-selections:updated', function(event) {
            const cartData = event?.detail?.data;
            const bundlePayload = cartData?.cartPayload;
            const isValid = cartData?.isSelectionsValid;

            // Store the bundle payload globally so productAddToCart can use it
            window.bundleCartPayload = bundlePayload;

            // cart button is initially disabled until bundle selections are valid
            const buyNowButton = $('.btn-buy-now');
            const addToCartBtn =
                document.querySelector('.btn-add-to-cart') ||
                document.querySelector('[data-sticky-add]');

            if (addToCartBtn) {
                if (!isValid) {
                    addToCartBtn.classList.add('disabled');
                    addToCartBtn.disabled = true;
                    buyNowButton.prop('disabled', true);
                    $('.angel-product-sticky__add').prop('disabled', true);
                    $('.angel-product-sticky__buy').prop('disabled', true);
                } else {
                    addToCartBtn.classList.remove('disabled');
                    addToCartBtn.disabled = false;
                    buyNowButton.disabled = false;
                    buyNowButton.prop('disabled', false);
                    $('.angel-product-sticky__add').prop('disabled', false);
                    $('.angel-product-sticky__buy').prop('disabled', false);
                }
            }
        });

        function getProductAddToCartButton(triggerEl) {
            if (triggerEl && (triggerEl.matches('.btn-add-to-cart, [data-sticky-add]') || triggerEl.closest('[data-sticky-add]'))) {
                return triggerEl.closest('[data-sticky-add]') || triggerEl;
            }
            return (
                document.querySelector('.btn-add-to-cart') ||
                document.querySelector('[data-sticky-add]')
            );
        }

        window.productAddToCart = function(triggerEl) {
          const addToCartBtn = getProductAddToCartButton(triggerEl);

          if (!addToCartBtn || addToCartBtn.disabled) {
              return;
          }

          if (typeof $ === 'undefined') {
              return;
          }

          function setAddToCartLoading(loading) {
              $('.add-to-cart-progress').toggleClass('d-none', !loading);
              $('.add-to-cart-icon').toggleClass('d-none', loading);
              $('.angel-product-sticky__add-progress').toggleClass('d-none', !loading);
              $('.angel-product-sticky__add-content').toggleClass('d-none', loading);
              if (loading) {
                  $('.btn-add-to-cart').prop('disabled', true);
                  $('.angel-product-sticky__add').prop('disabled', true);
              } else {
                  var mainAdd = document.querySelector('.btn-add-to-cart');
                  var stickyAdd = document.querySelector('[data-sticky-add]');
                  if (mainAdd) {
                      mainAdd.disabled = mainAdd.classList.contains('disabled');
                      $('.angel-product-sticky__add').prop('disabled', mainAdd.disabled);
                  } else if (stickyAdd) {
                      stickyAdd.disabled = stickyAdd.classList.contains('disabled');
                  }
              }
          }

          var mainAddLoader = $('.add-to-cart-progress');
          var stickyAddLoader = $('.angel-product-sticky__add-progress');
          if ((mainAddLoader.length && !mainAddLoader.hasClass('d-none')) ||
              (stickyAddLoader.length && !stickyAddLoader.hasClass('d-none'))) {
              return;
          }

          setAddToCartLoading(true);

          var stickyQty = parseInt($('[data-qty-value]').val(), 10);
          var selectQty = parseInt($('#product-quantity').val(), 10);
          var quantity = (stickyQty > 0 ? stickyQty : (selectQty > 0 ? selectQty : 1));
          var productId = $('#product-id').val() || '{{ product.selected_product.id }}';

          if (window.AngelCartToast && typeof window.AngelCartToast.syncProductFormQuantity === 'function') {
              quantity = window.AngelCartToast.syncProductFormQuantity(quantity);
          } else {
              var qtySelect = document.getElementById('product-quantity');
              if (qtySelect) {
                  qtySelect.value = String(quantity);
              }
          }

          if (!window.zid || !window.zid.cart || !window.zid.cart.addProduct) {
              setAddToCartLoading(false);
              window.zid?.toaster?.showError('{{ _("Cart service not available") }}');
              return;
          }

          const bundlePayload = window.bundleCartPayload;
          const needsFormId = !!bundlePayload ||
            (document.getElementById('product-form') &&
              (document.getElementById('product-form').getAttribute('data-is-bundle') === 'true' ||
               document.getElementById('product-form').getAttribute('data-has-custom-fields') === 'true'));

          const addProductOptions = bundlePayload
            ? Object.assign({}, bundlePayload, {
                form_id: 'product-form',
                product_id: productId,
                quantity: quantity
              })
            : (needsFormId
              ? { form_id: 'product-form', product_id: productId, quantity: quantity }
              : { product_id: productId, quantity: quantity });

          const addPromise =
            window.AngelCartToast && typeof window.AngelCartToast.addToCart === 'function'
              ? window.AngelCartToast.addToCart(addProductOptions, {}, addToCartBtn)
              : window.zid.cart.addProduct(addProductOptions, {
                  showErrorNotification: false,
                });

          addPromise
              .then(function () {
                  setAddToCartLoading(false);
              })
              .catch(function () {
                  setAddToCartLoading(false);
              });
      };

        async function sendProductNotifyMe() {
          $('.send-notify-progress').removeClass('d-none');

          const countryCode = '+' + ($('.send-notify-country-key').val() || '966');
          const productId = $('.send-notify-product-id').val();
          const email = $('.send-notify-email').val();
          const name = $('.send-notify-name').val();

          let phone = '';
          const rawPhone = $('.send-notify-phone').val();
          if (rawPhone) {
              phone = countryCode + rawPhone;
          }

          const baseUrl = "{{ store.permalink }}";
          const payload = {
              customer_email: email,
              customer_phone_number: phone,
              customer_name: name
          };

          const url = baseUrl + 'api/v1/products/' + encodeURIComponent(productId) + '/stock-alerts';

          try {
              const res = await fetch(url, {
                  method: 'POST',
                  headers: {
                      'Content-Type': 'application/json'
                  },
                  body: JSON.stringify(payload)
              });

              if (res.ok) {
                  let data = null;
                  try {
                      data = await res.json();
                  } catch (e) {
                      // Ignore JSON parse errors
                  }

                  if (!data || (data && data.status === 'success')) {
                      window.zid?.toaster?.showSuccess('{{ _("Send Successfully") }}');
                  } else if (data && data.data && data.data.message) {
                      window.zid?.toaster?.showError(JSON.stringify(data.data.message));
                  } else {
                      window.zid?.toaster?.showError('{{ _("Failed to send alert request") }}');
                  }
              } else {
                  let errData = null;
                  try {
                      errData = await res.json();
                  } catch (e) {
                      // Ignore JSON parse errors
                  }
                  
                  const msg = (errData && errData.data && errData.data.message)
                      || (errData && errData.detail)
                      || 'HTTP ' + res.status;

                  window.zid?.toaster?.showError(msg);
              }

          } catch (error) {
              var errorMessage = '{{ _("Failed to send alert request") }}';

              window.zid?.toaster?.showError(errorMessage);
          } finally {
              $('.send-notify-progress').addClass('d-none');
          }
        };

        function productOptionsChanged(selected_product) {
            var hasPreorder = $('[data-has-preorder]').attr('data-has-preorder') === 'true';
            var canPreorder = $('[data-can-preorder]').attr('data-can-preorder') === 'true';
            var stockBehavior = $('[data-stock-behavior]').attr('data-stock-behavior') || '';

            if (selected_product) {
                $('#product-id').val(selected_product.id);
                $('.send-notify-product-id').val(selected_product.id);

                var isBuyable;
                if (stockBehavior === 'IN_STOCK_ONLY') {
                    isBuyable = selected_product.in_stock;
                } else {
                    isBuyable = selected_product.in_stock || canPreorder;
                }

                if (isBuyable) {
                    // Selected a variant that can be ordered (in stock OR preorder allowed).
                    if (selected_product.formatted_sale_price) {
                        $('.product-formatted-price').html(selected_product.formatted_sale_price);
                        $('.product-formatted-price-old').html(selected_product.formatted_price);
                        $('.product-formatted-price-discount').html('{{ _("Discount") }}' + ' ' + selected_product.discount_percentage + '%');
                        $('.angel-variant-price-box__current').addClass('angel-product-price--sale');
                        $('.angel-product-sticky__price').addClass('angel-product-sticky__price--sale');
                    } else {
                        $('.product-formatted-price').html(selected_product.formatted_price);
                        $('.product-formatted-price-old').html('');
                        $('.product-formatted-price-discount').html('');
                        $('.angel-variant-price-box__current').removeClass('angel-product-price--sale');
                        $('.angel-product-sticky__price').removeClass('angel-product-sticky__price--sale');
                    }

                    if (selected_product.weight && selected_product.weight.value) {
                        $('.div-product-weight').removeClass('d-none');
                        $('.div-product-weight .product-weight').html(selected_product.weight.value + ' ' + selected_product.weight.unit);
                    } else {
                        $('.div-product-weight').addClass('d-none');
                    }

                    if (selected_product.sku) {
                        $('.div-product-sku').removeClass('d-none');
                        $('.div-product-sku .product-sku').html(selected_product.sku);
                    } else {
                        $('.div-product-sku').addClass('d-none');
                    }

                    {% if store.settings.products.low_stock_label_enabled %}
                    var store_low_stock_limit = {{ store.settings.products.low_stock_quantity_threshold }};
                    var low_stock_message = '{{ _("Remaining %s only") }}';

                    if (!selected_product.is_infinite && selected_product.quantity < store_low_stock_limit) {
                        $('.low-quantity-section').removeClass('d-none').addClass('d-inline-block');
                        $('.low-quantity-section .low-quantity').html(selected_product.low_stock_quantity);
                    } else {
                        $('.low-quantity-section').removeClass('d-inline-block').addClass('d-none');
                    }
                    {% endif %}

                    var selectQuantity = '';

                    if (selected_product.is_infinite) {
                        selected_product.quantity = 100;
                    }

                    if (selected_product.quantity > 0) {
                        var quantityMax;
                        if (selected_product.quantity > 100) {
                            quantityMax = 100;
                        } else {
                            quantityMax = selected_product.quantity;
                        }
                        selectQuantity = '<option value="1" selected>1</option>';
                        for (var i = 2; i <= quantityMax; i++) {
                            selectQuantity += '<option value="' + i + '">' + i + '</option>';
                        }
                    }

                    $('.select-quantity').html(selectQuantity);
                    $('#product-quantity').trigger('change');

                    $('.product-buttons').removeClass('d-none');
                    $('.section-out-of-stock-notify-me').addClass('d-none');

                    $('.btn-add-to-cart span').html(hasPreorder ? '{{ _("Preorder now") }}' : '{{ _("add to cart") }}');

                    updateProductImages(selected_product);
                } else {
                    // Variant is sold out and preorder is not allowed (or exhausted).
                    if (selected_product.formatted_sale_price) {
                        $('.product-formatted-price').html(selected_product.formatted_sale_price);
                        $('.product-formatted-price-old').html(selected_product.formatted_price);
                        $('.product-formatted-price-discount').html('{{ _("Discount") }}' + ' ' + selected_product.discount_percentage + '%');
                        $('.angel-variant-price-box__current').addClass('angel-product-price--sale');
                        $('.angel-product-sticky__price').addClass('angel-product-sticky__price--sale');
                    } else {
                        $('.product-formatted-price').html(selected_product.formatted_price);
                        $('.product-formatted-price-old').html('');
                        $('.product-formatted-price-discount').html('');
                        $('.angel-variant-price-box__current').removeClass('angel-product-price--sale');
                        $('.angel-product-sticky__price').removeClass('angel-product-sticky__price--sale');
                    }
                    $('.select-quantity').html('');
                    $('#product-quantity').trigger('change');

                    $('.product-buttons').addClass('d-none');
                    $('.section-out-of-stock-notify-me').removeClass('d-none');
                    $('.btn-add-to-cart span').html('{{ _("Option not available") }}');

                    if (selected_product.sku) {
                        $('.div-product-sku').removeClass('d-none');
                        $('.div-product-sku .product-sku').html(selected_product.sku);
                    } else {
                        $('.div-product-sku').addClass('d-none');
                    }
                    updateProductImages(selected_product);
                }
            } else {
                // Variant doesn't exist.
                $('.select-quantity').html('');
                $('#product-quantity').trigger('change');
                if (canPreorder) {
                    $('.product-buttons').removeClass('d-none');
                    $('.section-out-of-stock-notify-me').addClass('d-none');
                    $('.btn-add-to-cart span').html('{{ _("Preorder now") }}');
                } else {
                    $('.product-buttons').addClass('d-none');
                    $('.section-out-of-stock-notify-me').removeClass('d-none');
                    $('.btn-add-to-cart span').html('{{ _("Option not available") }}');
                }

                updateProductImages(selected_product);
            }
        }

        function updateProductImages(selected_product) {
            if (selected_product && selected_product.media) {
                productImages = selected_product.media;
                if (window.AngelProductPage && typeof AngelProductPage.rebuildGallery === 'function') {
                    var productTitle = document.querySelector('.angel-product-info h1');
                    AngelProductPage.rebuildGallery(productImages, productTitle ? productTitle.textContent.trim() : '');
                }
                var stickyThumb = document.querySelector('.angel-product-sticky__thumb');
                if (stickyThumb && productImages.length && productImages[0].image) {
                    stickyThumb.src = productImages[0].image.medium || productImages[0].image.full_size || '';
                }
            }
        }

        $('#product-description-a').click(function(event) {
            event.preventDefault();

            var detailsTab = document.querySelector('.angel-product-tabs__btn[data-tab="details"]');
            if (detailsTab && !detailsTab.classList.contains('is-active')) {
                detailsTab.click();
            }

            var scrollOffset;
            if (window.matchMedia('(max-width: 768px)').matches) {
                scrollOffset = 15;
            } else {
                scrollOffset = 150;
            }
            
            var targetElement = $($(this).attr('href'));
            if (targetElement.length) {
                $('html, body').animate({
                    scrollTop: targetElement.offset().top - scrollOffset
                }, 500);
            }
        });

        function addReviewButtonChecks() {
            if (!window.customerAuthState || !window.customerAuthState.isAuthenticated) {
                $('#add-review-btn').css('display', 'none');
                $('#add-review-link').removeClass('d-none');
                $('#add-review-link').attr('href', '/auth/login?redirect_to=' + window.location.pathname.replace('/', ''));
                $('#add-review-link').on('click', function(e) {
                    e.preventDefault();
                    handleLoginAction(window.location.pathname.replace('/', ''));
                    return false;
                });
            }
        }

        $(document).ready(function() {
            if (customerWishlistIds && Array.isArray(customerWishlistIds)) {
                fillWishlistItems(customerWishlistIds.map(function(id) { return { id: id }; }));
            }
        });


        document.addEventListener('zid-customer-fetched', function(event) {
            var customer = event.detail.customer;
            if (customer && customer.mobile) {
                $('.send-notify-name').val(customer.name || '');
                $('.send-notify-email').val(customer.email || '');
                $('.send-notify-country-key').val(customer.mobile.substring(0, 3) || '966');
                $('.send-notify-phone').val(customer.mobile.substring(3) || '');
            }
        });

        // Product Image Video  
        function getIframeLink(videoLink) {
            if (!videoLink || typeof videoLink !== 'string') {
                return null;
            }

            const videoIdMatch = videoLink.match(
                /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?|.*[?&]v=)|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
            );

            if (videoIdMatch && videoIdMatch[1]) {
                const videoLinkId = videoIdMatch[1];
                return 'https://www.youtube.com/embed/' + videoLinkId + '?autoplay=1&enablejsapi=1';
            }

            return null;
                }

        function showIframe(elm, imageVideoSrc) {
            if (!elm || !imageVideoSrc) {
                return;
            }

            const iframeLink = getIframeLink(imageVideoSrc);
            if (!iframeLink) {
                return;
            }

            const iframeElem = $(elm).parent(".image-link").siblings(".iframe-video").children("iframe");
            $(elm).parent(".image-link").siblings(".iframe-video").removeClass("d-none");
            
            if ($(iframeElem).attr("src") !== iframeLink) {
                $(iframeElem).attr("src", iframeLink);
            }
        }

        function hideIframe(elm) {
            if (!elm) {
                return;
            }

            $(elm).parent(".iframe-video").addClass("d-none");
            $(elm).siblings("iframe").attr("src", "");
        }

        $(document).on('click', '.variant-image-wrapper a', function(event) {
            event.preventDefault();

            var elm = event.currentTarget;
            var varId = $(elm).attr('data-link-var-id');
            var images = [];

            $("div[data-var-id='" + varId + "'] img").each(function() {
                var imageUrl = $(this).attr('data-image-url');
                if (imageUrl) {
                    images.push(imageUrl);
                }
            });

            var slideIndex = parseInt($(elm).attr('data-index'), 10) || 0;
            if (typeof openPhotoSwiper === 'function') {
                openPhotoSwiper(images, slideIndex);
            }
        });
    </script>

{% endblock %}
