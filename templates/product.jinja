{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ 'ekko-lightbox.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ 'swiper-bundle.min.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ ('product-details.css?v=' ~ ver) | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ ('angel-product.css?v=' ~ ver) | asset_url }}" />
{% endblock %}


{% block main_content %}

    {% if product %}
        {% set page_product = product %}
        {% set selected_product = selected_product if selected_product is defined else product.selected_product %}
        {% set has_preorder = product.effective_preorder_campaign is not none %}
        {% set can_preorder = product.can_be_preordered %}
        {% set preorder_stock_behavior = product.preorder_stock_behavior %}
        {% set can_buy = (selected_product and (selected_product.in_stock or can_preorder)) %}
    {% else %}
        {% set has_preorder = false %}
        {% set can_preorder = false %}
        {% set preorder_stock_behavior = '' %}
        {% set can_buy = false %}
    {% endif %}

    <section class="product products-details-page angel-product-page"
             data-has-preorder="{{ 'true' if has_preorder else 'false' }}"
             data-can-preorder="{{ 'true' if can_preorder else 'false' }}"
             data-stock-behavior="{{ preorder_stock_behavior or '' }}">
        <div class="container pb-5">
            <section class="products-details mb-5">
                <div>
                    <div class="row angel-product-details-wrapper">
                        {% if product %}

                        <div class="col-product-image-wrapper">
                            {% include 'components/angel-product-gallery.jinja' %}
                        </div>

                        <div class="col-product-info angel-product-info {% if product.selected_product.media | length <= 1 %}col-product-info-single-image{% endif %}">

                            <section class="angel-product-info-main">
                                {% if product.badge %}
                                   {% include 'vitrin:products/badge.jinja' %}
                                {% endif %}
                                {% if product.preorder_campaign %}
                                    {% include 'vitrin:products/preorder_badge.jinja' %}
                                {% endif %}

                            {% if product.categories and product.categories | length > 0 %}
                                {% set brand_cat = product.categories[0] %}
                                {% set brand_cat_url = (brand_cat.url | default('', true)) | trim or url_for('category_details', category_id=brand_cat.id, slug=brand_cat.slug or brand_cat.id) %}
                                <div class="angel-product-brand">
                                    <a href="{{ brand_cat_url }}" class="angel-product-brand__logo" aria-label="{{ brand_cat.name }}">
                                        {% if brand_cat.cover_image %}
                                            <img src="{{ image_url(brand_cat.cover_image, w=160, q=90, f='auto') }}" alt="" loading="lazy" width="64" height="64" />
                                        {% elif brand_cat.image %}
                                            <img src="{{ image_url(brand_cat.image, w=160, q=90, f='auto') }}" alt="" loading="lazy" width="64" height="64" />
                                        {% else %}
                                            <span class="angel-product-brand__placeholder" aria-hidden="true">{{ (brand_cat.name | default('', true))[:1] }}</span>
                                        {% endif %}
                                    </a>
                                    <div class="angel-product-brand__meta">
                                        <p class="angel-product-brand__authentic">{{ _("100% authentic product") }}</p>
                                        <p class="angel-product-brand__more">
                                            {{ _("Click for more from brand") }}
                                            <a href="{{ brand_cat_url }}">{{ brand_cat.name }}</a>
                                        </p>
                                    </div>
                                </div>
                            {% endif %}

                                <h1 class="angel-product-title">{{ product.name | safe }}</h1>

                                {# <div class="d-flex flex-column flex-lg-row product-features angel-product-meta-strip angel-product-rating-below-title">
                                    {% if product.rating %}
                                        <div>
                                            {% set rating=product.rating.average %}{% include 'components/rating-stars.jinja' %}
                                            {% if product.rating.total_count > 0 %}<span class="product-card-rating-count">({{ product.rating.total_count }})</span>{% endif %}
                                        </div>
                                    {% endif %}
                                    {% if product.sold_products_count %}
                                        <div class="product-count d-flex align-items-center">
                                            <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                            <span class="lang">{{ _("Sold more than %s times") | format(product.sold_products_count) }}</span>
                                        </div>
                                    {% elif product.selected_product.sold_products_count %}
                                        <div class="product-count d-flex align-items-center">
                                            <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                            <span class="lang">{{ _("Sold more than %s times") | format(product.selected_product.sold_products_count) }}</span>
                                        </div>
                                    {% endif %}

                                    {% if product.bundle_offer %}
                                    <div class="bundle-offer-section">
                                        <span class="icon-gift" style="color: red; font-size: 14px"></span>&nbsp;
                                        <span class="bundle-offer-title" style="unicode-bidi: isolate">{{ product.bundle_offer.name }}</span>
                                    </div>
                                    {% endif %}
                                </div> #}

                                {% if product.short_description %}
                                    <div class="text-short-description">{{ product.short_description | safe }}...
                                        <a id="product-description-a" href="#product-tabs" class="angel-product-read-more">{{ _("Read more") }}</a>
                                    </div>
                                {% endif %}

                                {% if not (product.has_variants or product.has_options) %}
                                <div class="angel-product-price-block angel-product-price-stack">
                                    <div class="angel-product-price-stack__row">
                                        <h2 class="product-formatted-price theme-text-primary {% if product.selected_product.formatted_sale_price %}angel-product-price--sale{% endif %}">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_sale_price }}{% else %}{{ product.selected_product.formatted_price }}{% endif %}</h2>
                                        <p class="angel-product-price-stack__oldwrap mb-0">
                                            <del class="product-formatted-price-old">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_price }}{% endif %}</del>
                                        </p>
                                    </div>
                                </div>
                                {% endif %}

                                <div class="angel-product-stock-rows">
                                    {% if not can_buy %}
                                    <div class="angel-product-stock angel-product-stock--depleted is-unavailable">
                                        <span class="angel-product-stock__label">{{ _("Quantity depleted") }}</span>
                                    </div>
                                    {% endif %}
                                    <div class="angel-product-stock {% if can_buy %}is-available{% else %}is-unavailable{% endif %}">
                                        {% if can_buy %}<span class="angel-product-stock__dot" aria-hidden="true"></span>{% endif %}
                                        <span class="angel-product-stock__label angel-product-stock__label--strong">{% if can_buy %}{{ _("Available") }}{% else %}{{ _("Out of stock") }}{% endif %}</span>
                                    </div>
                                </div>

                                {% if can_buy and not safeget(store, 'settings.general.availability.closed_now') and not product.preorder_campaign %}
                                {% set sale_ends_at = (
                                    product.selected_product.sale_price_date_to
                                    | default(product.selected_product.sale_price_end_date, true)
                                    | default(product.selected_product.discount_end_date, true)
                                    | default(product.sale_price_date_to, true)
                                    | default(product.discount_end_date, true)
                                    | default('', true)
                                ) | trim %}
                                {% set show_sale_urgency = product.selected_product.formatted_sale_price or product.discount_percentage %}
                                {% if show_sale_urgency %}
                                <section class="angel-product-urgency"{% if sale_ends_at %} data-sale-ends="{{ sale_ends_at | e }}"{% endif %}>
                                    <p class="angel-product-urgency__countdown{% if not sale_ends_at %} angel-product-urgency__countdown--no-timer{% endif %}">
                                        <i class="sicon-time align-middle"></i>
                                        <span class="angel-product-urgency__countdown-text">{{ _("Remaining until the discount ends:") }}</span>
                                        <span class="angel-product-urgency__timer" data-urgency-countdown{% if sale_ends_at %} data-countdown-end="{{ sale_ends_at | e }}"{% endif %} aria-live="polite"></span>
                                    </p>
                                    <div class="angel-product-urgency__box">
                                        <div class="angel-product-urgency__copy">
                                            <h3 class="angel-product-urgency__title">{{ _("Why wait?") }}</h3>
                                            <p class="angel-product-urgency__sub">{{ _("Get the product directly now") }}</p>
                                        </div>
                                        <button type="button" class="angel-product-urgency__buy" onclick="zidProductBuyNow()">
                                            <span>{{ _("Order it now") }}</span>
                                            <img class="angel-product-urgency__buy-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="18" height="18" alt="" />
                                        </button>
                                    </div>
                                </section>
                                {% endif %}
                                {% endif %}

                                {% if product.categories and product.categories | length > 0 %}
                                {% set class_cat = product.categories[0] %}
                                {% set class_cat_url = (class_cat.url | default('', true)) | trim or url_for('category_details', category_id=class_cat.id, slug=class_cat.slug or class_cat.id) %}
                                <div class="angel-product-classification">
                                    <span class="angel-product-classification__label">{{ _("Product classification:") }}</span>
                                    <a href="{{ class_cat_url }}">{{ class_cat.name }}</a>
                                </div>
                                {% endif %}

                                {% if product.keywords and product.keywords | length > 0 %}
                                <div class="angel-product-tags">
                                    {% for kw in product.keywords %}
                                        {% if kw.url is defined and kw.url %}
                                            <a class="angel-product-tags__pill" href="{{ kw.url }}">#{{ kw.name | default(kw, true) }}</a>
                                        {% else %}
                                            <a class="angel-product-tags__pill" href="/products?search={{ kw | urlencode }}">#{{ kw }}</a>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                                {% endif %}

                                {% if product.discount_percentage %}
                                <div class="angel-product-order-offer">
                                    <h2 class="angel-product-order-offer__title">{{ _("%(pct)s%% discount on order") | format(pct=product.discount_percentage) }}</h2>
                                    <p class="angel-product-order-offer__sub">{{ _("Do not miss this exclusive order discount.") }}</p>
                                    <div class="angel-product-order-offer__box">
                                        <div class="angel-product-coupon-row">
                                            <input type="text" class="angel-product-coupon-row__input" placeholder="{{ _('Enter discount coupon') }}" autocomplete="off" />
                                            <button type="button" class="angel-product-coupon-row__btn" onclick="window.location.href='/cart'">{{ _("Apply") }}</button>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}

                                <div>
                                    {% include 'vitrin:products/loyalty_points_widget.jinja' %}
                                </div>

                                <div>
                                    {% include 'vitrin:products/payment_widgets.jinja' %}
                                </div>
                                <div>
                                    {% include 'vitrin:products/preorder_countdown.jinja' %}
                                </div>
                            </section>


                            {# <div class="border-product"></div>
                            <div style="margin-bottom: 25px" class="div-product-sku {% if not product.selected_product.sku %}d-none{% endif %}">
                                <h4 class="product-title">{{ _("product sku") }}</h4>
                                <div class="product-sku">
                                    {{ product.selected_product.sku }}
                                </div>
                            </div> #}

                            <div style="margin-bottom: 25px" class="div-product-weight {% if not (product.selected_product.weight and product.selected_product.weight.value) %}d-none{% endif %}">
                                <h4 class="product-title">{{ _("Weight") }}</h4>
                                <div class="product-weight">
                                    {{ product.selected_product.weight.value }}&nbsp;{{ product.selected_product.weight.unit }}
                                </div>
                            </div>

                            <form id="product-form"{% if product.custom_input_fields %} data-has-custom-fields="true"{% endif %}{% if product.product_class == 'dynamic_bundle' %} data-is-bundle="true"{% endif %}>
                                <input id="product-id" type="hidden" value="{{ product.selected_product.id }}">

                                <div class="size-box">
                                    {% if product.has_variants or product.has_options %}
                                    <div class="angel-variant-panel" data-select-label="{{ _('Select') | e }}">
                                        <script type="application/json" id="angel-product-variant-data">{{ {
                                            'id': product.id,
                                            'options': product.options,
                                            'variants': product.variants,
                                            'selected_product': product.selected_product
                                        } | tojson }}</script>
                                        {% include 'vitrin:products/variants_list.jinja' %}
                                        <div class="angel-variant-price-box">
                                            <div class="angel-variant-price-box__label-wrap">
                                                <span class="angel-variant-price-box__label">
                                                    <i class="sicon-dollar-cash text-xs" aria-hidden="true"></i>
                                                    {{ _("Price") }}
                                                </span>
                                            </div>
                                            <div class="angel-variant-price-box__values">
                                                <span class="product-formatted-price theme-text-primary angel-variant-price-box__current {% if product.selected_product.formatted_sale_price %}angel-product-price--sale{% endif %}">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_sale_price }}{% else %}{{ product.selected_product.formatted_price }}{% endif %}</span>
                                                <del class="product-formatted-price-old angel-variant-price-box__old">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_price }}{% endif %}</del>
                                            </div>
                                        </div>
                                    </div>
                                    {% else %}
                                    {% include 'vitrin:products/variants_list.jinja' %}
                                    {% endif %}

                                    <!-- new custom fields update -->
                                    {% if product.custom_input_fields  %}
                                        <div class="border-product" style="margin-top: 25px"></div>
                                        {% include 'vitrin:products/custom_input_fields.jinja' %}
                                    {% endif %}
                                </div>
                                
                                <section class="angel-product-tabs-section" id="product-tabs" data-product-id="{{ product.id }}">
                                        <div class="angel-product-tabs__nav" role="tablist">
                                            <button type="button" class="angel-product-tabs__btn is-active" role="tab" aria-selected="true" data-tab="details">
                                                <i class="sicon-newspaper-alt text-xs ltr:mr-1 rtl:ml-1"></i>
                                                <span class="angel-product-tabs__btn-label">{{ _("Details") }}</span>
                                            </button>
                                            {% if store.settings.products.reviews_enabled or store.settings.products.questions_enabled %}
                                            <button type="button" class="angel-product-tabs__btn" role="tab" aria-selected="false" data-tab="ratings">
                                                <i class="sicon-star text-xs ltr:mr-1 rtl:ml-1"></i>
                                                <span class="angel-product-tabs__btn-label">{{ _("Ratings") }}</span>
                                            </button>
                                            {% endif %}
                                        </div>
                                        <div class="angel-product-tabs__body">
                                        <div class="angel-product-tabs__panel is-active" role="tabpanel" data-panel="details" id="product-description">


                                    {% if product.metafields %}
                                            <div class="description-paragrah text-justify description-text-clear mb-4">
                                                {% set entity = product %}
                                                {% include 'vitrin:shared/metafields.jinja' %}
                                            </div>
                                    {% endif %}

                                    {% if product.description %}
                                            {% autoescape false %}
                                                <div class="description-paragrah text-justify description-text-clear">
                                                    {{ product.description }}
                                                </div>
                                            {% endautoescape %}
                                    {% endif %}

                                {# {% if product.has_variants %}
                                    <section class="product-selection mt-5">
                                        <div>
                                            <div class="d-flex align-items-center">
                                                <div class="description-icon">
                                                    <span class="icon-format_list_bulleted"></span>
                                                </div>
                                                <div class="description-title">
                                                    {{ _("product description") }}
                                                </div>
                                            </div>

                                            <div class="card-table d-none d-lg-block">
