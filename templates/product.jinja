                                                                                        <div class="box-1-1">
                                                                                            <div class="content">
                                                                                                <a data-index="{{ loop.index0 }}" data-link-var-id="{{ variant.id }}" class="d-flex align-items-center justify-content-center" style="width: 100%; height: 100%;" >
                                                                                                    <img src="{{ image.image.medium }}" data-image-url="{{ image.image.full_size }}">
                                                                                                </a>
                                                                                            </div>
                                                                                        </div>

                                                                                    </div>
                                                                                {% endfor %}
                                                                            </div>
                                                                        {% else %}
                                                                            <span class="d-none d-lg-inline">{{ _("No images") }}</span>
                                                                        {% endif %}
                                                                    </div>

                                                                    <div class="col m-col">
                                                                        <span class="variant-name-sm d-inline-block d-lg-none">{{ _("price") }}</span>
                                                                        {% if variant.formatted_sale_price %}
                                                                            <h4 style="font-size: 1.2rem" class="price-detail d-inline-block">{{ variant.formatted_sale_price }}
                                                                                <del>{{ variant.formatted_price }}</del>
                                                                            </h4>
                                                                        {% else %}
                                                                            <h4 class="d-inline-block" style="font-size: 1.2rem">{{ variant.formatted_price }}</h4>
                                                                        {% endif %}
                                                                    </div>



                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}

                                        </div>
                                    </section>
                                {% endif %} #}

                                        </div>
                                        {% if store.settings.products.reviews_enabled or store.settings.products.questions_enabled %}
                                    <div class="angel-product-tabs__panel" role="tabpanel" data-panel="ratings">
                                        {% include 'components/angel-product-tab-ratings.jinja' %}
                                    </div>
                                    {% endif %}
                                        </div>
                                </section>

                                <div class="angel-product-trust__grid">
                                    <div class="angel-product-trust__item">
                                        <i class="sicon-gold-badge text-lg"></i>
                                        <h3 class="angel-product-trust__heading">{{ _("Exclusive brands") }}</h3>
                                    </div>
                                    <div class="angel-product-trust__item">
                                        <i class="sicon-chat-bubbles text-lg"></i>
                                        <h3 class="angel-product-trust__heading">{{ _("Technical support") }}</h3>
                                    </div>
                                    <div class="angel-product-trust__item">
                                        <i class="sicon-star-o text-lg"></i>
                                        <h3 class="angel-product-trust__heading">{{ _("Safe delivery") }}</h3>
                                    </div>
                                </div>

                                <div class="angel-product-payments">
                                    {% for payment_method in store.settings.checkout.payment_methods | default([]) %}
                                        <img src="{{ image_url(payment_method.icon, h=80, q=100) }}" alt="" loading="lazy" height="24" />
                                    {% endfor %}
                                </div>

                                {% if can_buy and (product.selected_product.is_infinite or product.selected_product.quantity > 0) %}
                                    <div class="select-quantity-div d-none" aria-hidden="true">
                                        <select id="product-quantity" name="quantity" class="select-quantity">
                                            {% if product.selected_product.is_infinite or product.selected_product.quantity > 100 %}
                                                {% set maxQuantity = 100 %}
                                            {% else %}
                                                {% set maxQuantity = product.selected_product.quantity %}
                                            {% endif %}
                                            {% for n in range(1, maxQuantity + 1) %}
                                                <option value="{{ n }}" {% if n == 1 %}selected{% endif %}>{{ n }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                {% endif %}

                                <div class="section-out-of-stock-notify-me {% if not can_buy %}d-block{% else %}d-none{% endif %}">
                                    <div class="border-product" style="margin-top: 15px"></div>
                                    <div>
                                        <h4 class="product-title">{{ _("This product is out of stock") }}</h4>
                                        <div class="notify-me-form-wrapper">
                                            <input type="hidden" class="send-notify-product-id" value="{{ product.selected_product.id }}">
                                            <div class="form-group form-notify-me">
                                                <h4>{{ _("Notify me when product is available") }}</h4>
                                                
                                                <input class="form-control send-notify-name" value="" type="text" placeholder="{{ _('Enter your name') }}" />
                                                <input class="form-control send-notify-email" type="email" value="" placeholder="{{ _('Enter your email') }}" />
                                                <div class="d-flex form-notify-me-phone-row">
                                                    <input class="form-control send-notify-country-key"
                                                        type="number"
                                                        placeholder="966" maxlength="4" />
                                                    <input class="form-control send-notify-phone" type="number"  value="" placeholder="{{ _('Enter your phone (Optional)') }}" maxlength="10" />
                                                </div>
                                                <div class="form-notify-me-submit-button-row">
                                                    <button type="button" class="btn btn-primary btn-send-notify" onclick="sendProductNotifyMe()">
                                                    <img class="send-notify-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"/>
                                                    {{ _("Send") }}
                                                    </button>
                                                </div>
                                            
                                            </div>
                                        </div>
                                    </div>
                                </div>


                            </form>
                            
                            <!-- Bundle Product Selection Container -->
                            {% if product.product_class == 'dynamic_bundle' %}
                                {% include 'vitrin:products/bundle-products.jinja' %}
                            {% endif %}

                            {# <div class="product-buttons {% if can_preorder or product.selected_product.in_stock %}d-block{% else %}d-none{% endif %}">
                                <div class="border-product"></div>
                                <div class="angel-product-cta-row d-flex align-center flex-wrap" style="gap: 10px;">
                                    <button class="btn btn-add-to-cart flex-grow-1" style="margin-bottom: 0" type="button" onclick="productAddToCart()">
                                        <div class="add-to-cart-icon fa fa-shopping-cart" style="mask: url({{ 'shopping-cart.svg' | asset_url }}) no-repeat center;"></div>
                                        <img class="add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="25" height="25" alt="" />
                                        <span>{% if product.preorder_campaign %}{{ _("Preorder now") }}{% else %}{{ _("add to cart") }}{% endif %}</span>
                                    </button>

                                    {% include 'vitrin:checkout/checkout_dialog.jinja' %}

                                    {% if not safeget(store, 'settings.general.availability.closed_now') and not product.preorder_campaign %}
                                    <button class="btn btn-buy-now flex-shrink-0 d-none" type="button" onclick="zidProductBuyNow()">
                                        <div class="buy-now-icon" style="mask: url({{ 'buy-now.svg' | asset_url }}) no-repeat center;"></div>
                                        <img class="buy-now-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="25" height="25" alt="" />
                                        <span>{{ _("Buy now") }}</span>
                                    </button>
                                    {% endif %}

                                    {% if store.settings.products.wishlist_enabled == true %}
                                        <span class="add-to-wishlist position-relative my-2" data-wishlist-id="{{ product.id }}">
                                            {% if not session.is_guest %}
                                            <a class="icon-heart-mask" onclick="addToWishlist(this, '{{ product.id }}')"></a>
                                            {% else %}
                                            <a class="icon-heart-mask" href="{{ url_for('login_page', query_params={"redirect_to": session.path} ) }}"></a>
                                            {% endif %}
                                            <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20"/>
                                        </span>
                                    {% endif %}
