{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}"/>
    <link rel="stylesheet" type="text/css" href="{{ 'swiper-bundle.min.css' | asset_url }}"/>
    <link rel="stylesheet" type="text/css" href="{{ ('angel-category.css?v=0.1.050') | asset_url }}"/>
{% endblock %}

{% block main_content %}

<div class="angel-category-page">
    <header class="angel-category-hero">
        <div class="container">
            <div class="angel-category-hero__inner">
                <div class="angel-category-hero__media" aria-hidden="true">
                    {% if store.logo %}
                        <img class="angel-category-hero__img" src="{{ image_url(store.logo, w=160, h=160, q=90, f='auto') }}" alt="" loading="lazy" width="88" height="88" />
                    {% else %}
                        <span class="angel-category-hero__img-placeholder">
                            <i class="sicon-store" aria-hidden="true"></i>
                        </span>
                    {% endif %}
                </div>
                <div class="angel-category-hero__content">
                    <div class="angel-category-hero__title-row">
                        <h1 class="angel-category-hero__title">{{ _("All products") }}</h1>
                    </div>
                    <nav class="angel-category-hero__breadcrumb" aria-label="{{ _('breadcrumb') }}">
                        <a href="/">{{ _("Home") }}</a>
                        <span class="angel-category-hero__breadcrumb-sep" aria-hidden="true">/</span>
                        <span class="angel-category-hero__breadcrumb-current">{{ _("All products") }}</span>
                    </nav>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="angel-category-page__layout">
            {% if products.filters | length > 0 %}
                <aside class="angel-category-page__sidebar" data-angel-filter-drawer aria-label="{{ _('Filter') }}">
                    <div class="angel-category-page__sidebar-head d-lg-none">
                        <span class="angel-category-page__sidebar-title">{{ _("Filter") }}</span>
                        <button type="button" class="angel-category-page__sidebar-close" data-angel-category-filter-close aria-label="{{ _('Close') }}">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="angel-side-filters-panel__inner">
                        <div id="angel-category-filters" class="angel-category-filters angel-side-filters">
                            {% set async = true %}
                            {% include 'vitrin:products/filters.jinja' %}
                        </div>
                        <button type="button" class="angel-category-filters__clear" data-angel-category-clear>
                            {{ _("Clear filter") }}
                        </button>
                    </div>
                </aside>
                <div class="angel-category-page__sidebar-backdrop d-lg-none" data-angel-category-filter-close hidden></div>
            {% endif %}

            <div class="angel-category-page__main">
                {% set count = products.count %}
                {% set has_products_filtration = (products.filters | length > 0) %}
                {% include 'components/angel-category-toolbar.jinja' %}

                <div id="products-list" class="angel-category-page__grid products-list">
                    {% for product in products.results | default([]) %}
                        {% set product = product %}
                        {% set index = key %}
                        {% include 'components/product-card.jinja' %}
                    {% endfor %}
                </div>

                {% if products.results | length == 0 %}
                    <p class="angel-category-page__empty">{{ _("No products") }}</p>
                {% endif %}

                <div class="angel-category-page__pagination-wrap">
                    {% set totalPages = products.pages_count %}
                    {% set currentPage = products.page %}
                    {% include 'components/pagination.jinja' %}
                </div>
            </div>
        </div>
        {% include 'components/angel-category-testimonial.jinja' %}
    </div>
</div>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}

{% block footer_scripts %}
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ ('angel-side-filters.js?v=0.1.5') | asset_url }}" defer></script>
    <script type="text/javascript" src="{{ ('angel-category.js?v=0.1.049') | asset_url }}" defer></script>
    <script>
        window.angelProductCardLabels = {
            chooseOptions: {{ _("Please choose product options first") | tojson }}
        };
        window.onProductAttributesTriggered = function () {
            var list = document.getElementById('products-list');
            var pagination = document.getElementById('product-pagination');
            if (list) {
                list.style.opacity = '0.4';
            }
            if (pagination) {
                pagination.style.opacity = '0';
            }
        };

        window.onProductAttributesChanged = function (htmlStr) {
            var html = $.parseHTML(htmlStr);
            var $html = $(html);
            var list = document.getElementById('products-list');
            var nextList = $html.find('#products-list').html();

            if (list && nextList) {
                list.innerHTML = nextList;
                list.style.opacity = '1';
            }

            var pagination = document.getElementById('product-pagination');
            var nextPagination = $html.find('#product-pagination').html();
            if (pagination && nextPagination) {
                pagination.innerHTML = nextPagination;
                pagination.style.opacity = '1';
            } else if (pagination) {
                pagination.style.opacity = '1';
            }

            if (window.AngelProductCard && window.AngelProductCard.init) {
                window.AngelProductCard.init(list || document);
            }
            if (window.AngelProductPage && window.AngelProductPage.bindGroupedQuickViewTriggers) {
                window.AngelProductPage.bindGroupedQuickViewTriggers(list || document);
            }
            if (window.bundleOffersLoader) {
                window.bundleOffersLoader.reload();
            }
            if (window.AngelCategoryPage && window.AngelCategoryPage.onProductsUpdated) {
                window.AngelCategoryPage.onProductsUpdated();
            }
        };
    </script>
{% endblock %}
